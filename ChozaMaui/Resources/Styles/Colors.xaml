<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════
         LA CHOZA — DESIGN SYSTEM v2.0
         Mobile-First POS — Paleta Premium
    ════════════════════════════════════════════════════ -->

    <!-- PRIMARIOS -->
    <Color x:Key="Primary">#EA580C</Color>
    <Color x:Key="PrimaryDark">#C2410C</Color>
    <Color x:Key="PrimaryPressed">#9A3412</Color>
    <Color x:Key="PrimaryLight">#FFF1E7</Color>
    <Color x:Key="PrimarySoft">#FED7AA</Color>

    <!-- Alias legado (compatibilidad) -->
    <Color x:Key="Orange">#EA580C</Color>
    <Color x:Key="OrangeLight">#FFF1E7</Color>

    <!-- FONDOS -->
    <Color x:Key="Surface">#F6F7F9</Color>
    <Color x:Key="SurfaceCard">#FFFFFF</Color>
    <Color x:Key="SurfaceElevated">#FFFFFF</Color>
    <Color x:Key="SurfaceSunken">#EEF2F6</Color>
    <Color x:Key="Gray100">#EEF2F6</Color>

    <!-- TEXTO -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#4B5563</Color>
    <Color x:Key="TextMuted">#8A94A6</Color>

    <!-- BORDES -->
    <Color x:Key="Border">#DDE3EA</Color>

    <!-- ESTADOS (semánticos) -->
    <Color x:Key="Success">#16A34A</Color>
    <Color x:Key="SuccessLight">#DCFCE7</Color>
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="DangerLight">#FEE2E2</Color>
    <Color x:Key="Info">#2563EB</Color>
    <Color x:Key="InfoLight">#DBEAFE</Color>
    <Color x:Key="Accent">#7C3AED</Color>
    <Color x:Key="AccentLight">#EDE9FE</Color>
    <Color x:Key="Neutral">#64748B</Color>
    <Color x:Key="NeutralLight">#E2E8F0</Color>

    <!-- ESTADOS MESA -->
    <Color x:Key="MesaLibre">#22C55E</Color>
    <Color x:Key="MesaOcupada">#F97316</Color>
    <Color x:Key="MesaPreparando">#3B82F6</Color>
    <Color x:Key="MesaLista">#8B5CF6</Color>
    <Color x:Key="MesaPendientePago">#EF4444</Color>
</ResourceDictionary>
