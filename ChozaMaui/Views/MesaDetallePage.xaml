<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.MesaDetallePage"
             x:DataType="vm:MesaDetalleViewModel"
             Title="{Binding Titulo}"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="True"
             BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <Grid BackgroundColor="#F97316" Padding="14,40,14,12">
                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="‹"
                                FontSize="30"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                Padding="0"
                                WidthRequest="44"
                                HeightRequest="44"
                                Command="{Binding VolverCommand}" />

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Titulo}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Label Text="{Binding ComedorTexto}"
                                   FontSize="12"
                                   TextColor="#FFEDD5" />
                        </VerticalStackLayout>

                        <controls:ConnectivityActionsView Grid.Column="2"
                                                          RefreshCommand="{Binding CargarCommand}"
                                                          VerticalOptions="Center" />
                    </Grid>
                </Grid>

                <VerticalStackLayout Padding="14" Spacing="14">

                    <Border BackgroundColor="White"
                            Stroke="#E2E8F0"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                        <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="#FEF2F2"
                                    StrokeShape="RoundRectangle 28"
                                    Stroke="Transparent"
                                    WidthRequest="56"
                                    HeightRequest="56">
                                <Label Text="🔔"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="Lista para entregar"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />
                                <Label Text="{Binding PedidosListosCount, StringFormat='{0} pedidos listos'}"
                                       FontSize="13"
                                       TextColor="#6b7280" />
                            </VerticalStackLayout>
                        </Grid>
                            <Button Text="ENTREGAR TODO"
                                    Command="{Binding EntregarTodoCommand}"
                                    IsEnabled="{Binding TienePedidosListos}"
                                    BackgroundColor="#22C55E"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="16"
                                    FontSize="12"
                                    HeightRequest="50" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="White"
                            Stroke="#E2E8F0"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="Resumen de la mesa"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                                    <Label Text="👥" FontSize="22" HorizontalTextAlignment="Center" />
                                    <Label Text="Capacidad" FontSize="11" TextColor="#6b7280" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Mesa.Capacidad, StringFormat='{0} pers.'}" FontSize="13" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                                    <Label Text="📋" FontSize="22" HorizontalTextAlignment="Center" />
                                    <Label Text="Pedidos" FontSize="11" TextColor="#6b7280" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding PedidosActivosCount, StringFormat='{0} activos'}" FontSize="13" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                                    <Label Text="◷" FontSize="22" HorizontalTextAlignment="Center" />
                                    <Label Text="Tiempo" FontSize="11" TextColor="#6b7280" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding TiempoMesaTexto}" FontSize="13" FontAttributes="Bold" TextColor="#111827" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                                    <Label Text="Total" FontSize="12" FontAttributes="Bold" TextColor="#f4511e" HorizontalTextAlignment="Center" />
                                    <Label Text="a cobrar" FontSize="10" TextColor="#f4511e" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding TotalMesaTexto}" FontSize="18" FontAttributes="Bold" TextColor="#f4511e" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Pedidos activos"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           Margin="2,2,0,-4" />

                    <Border IsVisible="{Binding TienePedidosActivos, Converter={StaticResource InvertBoolConverter}}"
                            BackgroundColor="White"
                            Stroke="#e2e8f0"
                            StrokeShape="RoundRectangle 14"
                            Padding="18">
                        <Label Text="No hay pedidos activos en esta mesa."
                               FontSize="14"
                               TextColor="#6b7280"
                               HorizontalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding PedidosActivos}"
                                         Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:PedidoResponse">
                                <Border BackgroundColor="White"
                                        Stroke="#e2e8f0"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="0">
                                    <Grid ColumnDefinitions="5,*">
                                        <BoxView Grid.Column="0"
                                                 Color="{Binding EstadoBorderColor, Converter={StaticResource HexToColorConverter}}"
                                                 CornerRadius="14,0,0,14" />
                                        <VerticalStackLayout Grid.Column="1" Padding="14,12" Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                                    <Label Text="{Binding Idpedido, StringFormat='Pedido #{0}'}"
                                                           FontSize="18"
                                                           FontAttributes="Bold"
                                                           TextColor="#111827" />
                                                    <Border BackgroundColor="{Binding EstadoBadgeBackground, Converter={StaticResource HexToColorConverter}}"
                                                            StrokeShape="RoundRectangle 7"
                                                            Stroke="Transparent"
                                                            Padding="8,3"
                                                            VerticalOptions="Center">
                                                        <Label Text="{Binding EstadoTextoVisual}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               TextColor="White" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                                <Label Grid.Column="1"
                                                       Text="{Binding Fecha, StringFormat='{0:hh:mm tt}'}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#111827" />
                                            </Grid>

                                            <Label Text="{Binding Usuario.NombreCompleto, StringFormat='Mesero: {0}'}"
                                                   FontSize="12"
                                                   TextColor="#6b7280"
                                                   HorizontalTextAlignment="End" />

                                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Detalle}"
                                                                 Spacing="5">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:PedidoDetalleResponse">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                            <Label Grid.Column="0"
                                                                   Text="{Binding Cantidad, StringFormat='{0}x'}"
                                                                   FontSize="13"
                                                                   TextColor="#374151" />
                                                            <Label Grid.Column="1"
                                                                   Text="{Binding Producto.Nombre}"
                                                                   FontSize="13"
                                                                   TextColor="#111827"
                                                                   LineBreakMode="TailTruncation" />
                                                            <Label Grid.Column="2"
                                                                   Text="{Binding Subtotal, StringFormat='${0:0.00}'}"
                                                                   FontSize="13"
                                                                   TextColor="#111827" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>

                                            <BoxView HeightRequest="1" Color="#e5e7eb" />

                                            <Grid ColumnDefinitions="*,Auto">
                                                <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                                    <Label Text="Total"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="#111827" />
                                                    <Label Text="{Binding Total, StringFormat='${0:0.00}'}"
                                                           FontSize="18"
                                                           FontAttributes="Bold"
                                                           TextColor="#f4511e" />
                                                </HorizontalStackLayout>

                                                <Button Grid.Column="1"
                                                        Text="✓  ENTREGAR ESTE PEDIDO"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EntregarPedidoCommand}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding PuedeEntregarse}"
                                                        BackgroundColor="#16a34a"
                                                        TextColor="White"
                                                        FontAttributes="Bold"
                                                        CornerRadius="8"
                                                        FontSize="12"
                                                        Padding="12,0"
                                                        HeightRequest="40" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Label Text="{Binding Mensaje}"
                           IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#374151"
                           HorizontalTextAlignment="Center" />

                    <Button Text="CERRAR MESA"
                            Command="{Binding CerrarMesaCommand}"
                            IsEnabled="{Binding PuedeCerrarMesa}"
                            IsVisible="{Binding EsAdmin}"
                            BackgroundColor="White"
                            BorderColor="#ef4444"
                            BorderWidth="1.5"
                            TextColor="#ef4444"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            HeightRequest="52"
                            Margin="0,8,0,18" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
