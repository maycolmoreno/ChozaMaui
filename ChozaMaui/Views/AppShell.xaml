<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ChozaMaui.Views"
       x:Class="ChozaMaui.Views.AppShell"
       Title="La Choza POS"
       Shell.NavBarIsVisible="True"
       Shell.TabBarIsVisible="True">

    <!-- Ruta para detalle de pedido (sin tab propio) -->
    <Shell.Resources>
        <Style TargetType="TabBar">
            <Setter Property="Shell.TabBarBackgroundColor" Value="#F26522" />
            <Setter Property="Shell.TabBarForegroundColor" Value="White" />
            <Setter Property="Shell.TabBarTitleColor" Value="White" />
            <Setter Property="Shell.TabBarUnselectedColor" Value="#FFE3D0" />
        </Style>
    </Shell.Resources>

    <TabBar>

        <!-- Pantalla 1: Mapa de mesas -->
        <Tab Title="Mapa">
            <ShellContent ContentTemplate="{DataTemplate views:MapaPage}" Route="mapa" />
        </Tab>

        <!-- Pantalla 2: POS -->
        <Tab Title="POS">
            <ShellContent ContentTemplate="{DataTemplate views:PosPage}" Route="pos" />
        </Tab>

        <!-- Pantalla 3: Pedidos -->
        <Tab Title="Pedidos">
            <ShellContent ContentTemplate="{DataTemplate views:PedidosPage}" Route="pedidos" />
        </Tab>

        <!-- Pantalla 4: Perfil -->
        <Tab Title="Perfil">
            <ShellContent ContentTemplate="{DataTemplate views:PerfilPage}" Route="perfil" />
        </Tab>

        <!-- Pantalla 5: Turnos -->
        <Tab Title="Turnos">
            <ShellContent ContentTemplate="{DataTemplate views:TurnoPage}" Route="turnos" />
        </Tab>

    </TabBar>

</Shell>
