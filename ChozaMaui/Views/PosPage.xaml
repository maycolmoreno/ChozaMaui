<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.PosPage"
             x:DataType="vm:PosViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="True"
             BackgroundColor="{StaticResource Surface}">

    <Grid>

        <!-- ══ VISTA PRINCIPAL (cuando NO se muestra éxito) ══ -->
        <Grid RowDefinitions="Auto,*"
              IsVisible="{Binding MostrarExito, Converter={StaticResource InvertBoolConverter}}">

            <controls:PosHeaderView Grid.Row="0"
                                    MostrarVolver="True"
                                    BackCommand="{Binding VolverCommand}"
                                    InicialesUsuario="{Binding InicialesUsuario}"
                                    NombreUsuario="{Binding NombreUsuarioHeader}"
                                    RolUsuario="{Binding RolUsuarioHeader}"
                                    Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                                    Kpi1Valor="{Binding HeaderKpi1Valor}"
                                    Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                                    Kpi2Valor="{Binding HeaderKpi2Valor}"
                                    Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                                    Kpi3Valor="{Binding HeaderKpi3Valor}"
                                    TotalAlertas="{Binding TotalAlertasHeader}"
                                    NotificacionesCommand="{Binding IrNotificacionesCommand}"
                                    RefreshCommand="{Binding CargarDatosCommand}" />

            <!-- ── SCROLL DE CONTENIDO ── -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding ProductosFiltrados}"
                            SelectionMode="None"
                            Margin="16,0,16,92">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <VerticalStackLayout Padding="0,14,0,10" Spacing="16">

                    <!-- Alerta pedido listo (banner top) -->
                    <Border BackgroundColor="{StaticResource WarningLight}"
                            Stroke="{StaticResource Warning}"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,10"
                            IsVisible="{Binding MostrarPedidoListo}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Text="!"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryPressed}"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="¡Pedido listo para entregar!"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PrimaryPressed}" />
                                <Label Text="{Binding MesaNumeroTexto}"
                                       FontSize="12"
                                       TextColor="{StaticResource PrimaryPressed}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="Ver"
                                    Command="{Binding VerDetallePedidoCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Padding="4,0" />
                        </Grid>
                    </Border>

                    <!-- ── BUSCAR PRODUCTO ── -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0"
                                HeightRequest="50">
                            <Grid>
                                <Entry Text="{Binding BusquedaProducto}"
                                       Placeholder="Buscar producto..."
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                        <Border Grid.Column="1"
                                BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="50" WidthRequest="48">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding MostrarTodosCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="☰"
                                   FontSize="18"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- ── CATEGORÍAS ── -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="8">
                            <!-- Todos -->
                            <Border BackgroundColor="{StaticResource Primary}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="14,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MostrarTodosCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="Todos"
                                       TextColor="White"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                            </Border>

                            <HorizontalStackLayout Spacing="8"
                                                   BindableLayout.ItemsSource="{Binding Categorias}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:CategoriaResponse">
                                        <Border BackgroundColor="White"
                                                Stroke="{StaticResource Border}"
                                                StrokeShape="RoundRectangle 20"
                                                Padding="14,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FiltrarPorCategoriaCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding Nombre}"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontAttributes="Bold" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- ── SECCIÓN PRODUCTOS ── -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Productos"
                               Style="{StaticResource SectionTitle}"
                               VerticalOptions="Center" />
                        <ActivityIndicator Grid.Column="1"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="22" WidthRequest="22" />
                    </Grid>

                    </VerticalStackLayout>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProductoResponse">
                                <Border BackgroundColor="White"
                                        Stroke="{StaticResource Border}"
                                        StrokeShape="RoundRectangle 16"
                                        Padding="10"
                                        HeightRequest="118">
                                    <Grid RowDefinitions="48,Auto,*" RowSpacing="4">

                                        <!-- Imagen / Emoji placeholder -->
                                        <Border Grid.Row="0"
                                                BackgroundColor="{StaticResource SurfaceSunken}"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 12">
                                            <Grid>
                                                <Label Text="+"
                                                       FontSize="22"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource TextMuted}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                                      <Image x:Name="ProductoCardImage"
                                                          Source="{Binding ImagenUrl, Converter={StaticResource StringToCachedImageSourceConverter}}"
                                                      Aspect="AspectFill"
                                                      HeightRequest="48"
                                                      WidthRequest="999"
                                                      IsVisible="{Binding ImagenUrl, Converter={StaticResource StringToBoolConverter}}" />
                                                  <ActivityIndicator IsRunning="{Binding Source={x:Reference ProductoCardImage}, Path=IsLoading}"
                                                            IsVisible="{Binding Source={x:Reference ProductoCardImage}, Path=IsLoading}"
                                                            Color="{StaticResource Primary}"
                                                            WidthRequest="18"
                                                            HeightRequest="18"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center" />
                                            </Grid>
                                        </Border>

                                        <!-- Nombre -->
                                        <Label Grid.Row="1"
                                               Text="{Binding Nombre}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />

                                        <!-- Precio + botón agregar -->
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Precio, StringFormat='${0:0.##}'}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Primary}"
                                                   VerticalOptions="Center" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource PrimaryLight}"
                                                    StrokeShape="RoundRectangle 10"
                                                    Stroke="Transparent"
                                                    HeightRequest="34" WidthRequest="34">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AgregarAlCarritoCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="+"
                                                       FontSize="20"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                    </Grid>
                                </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="18" Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>

            <!-- ── CARRITO FIJO ── -->
            <Border Grid.Row="1"
                    IsVisible="{Binding MostrarCarritoFijo}"
                    VerticalOptions="End"
                    Margin="12,0,12,10"
                    BackgroundColor="White"
                    Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 18"
                    Padding="12">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.14" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="6">
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10">
                        <Label Text="{Binding CarritoItemsTexto}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding EstadoPedidoTexto}"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding TotalTexto}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding ObservacionesResumenTexto}"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Text="VER PEDIDO"
                            Command="{Binding VerPedidoCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="40"
                            Padding="16,0"
                            FontSize="12"
                            FontAttributes="Bold" />
                </Grid>
            </Border>

            <!-- ── BOTTOM SHEET DEL PEDIDO ── -->
            <Grid Grid.RowSpan="2"
                  IsVisible="{Binding MostrarPedidoSheet}">
                <BoxView Color="#66000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CerrarPedidoSheetCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border VerticalOptions="End"
                        BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 24,24,0,0"
                        Padding="16,12,16,24">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,-4" Radius="20" Opacity="0.12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <BoxView WidthRequest="40"
                                 HeightRequest="4"
                                 CornerRadius="2"
                                 Color="{StaticResource Border}"
                                 HorizontalOptions="Center" />

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Pedido actual"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding MesaNumeroTexto}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource PrimaryLight}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BuscarClienteCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="+ Cliente"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                            </Border>
                        </Grid>

                        <Border BackgroundColor="{StaticResource PrimaryLight}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 12"
                                Padding="10,8"
                                IsVisible="{Binding TieneClienteSeleccionado}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Text="{Binding ClienteNombreTexto}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding ClienteEstadoTexto}"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <ScrollView MaximumHeightRequest="260">
                            <VerticalStackLayout Spacing="8"
                                                 BindableLayout.ItemsSource="{Binding Carrito}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:ItemCarrito">
                                        <Grid ColumnDefinitions="*,96,34"
                                              ColumnSpacing="10"
                                              Padding="0,4">
                                            <VerticalStackLayout Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Producto.Nombre}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Subtotal, StringFormat='${0:0.00}'}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Primary}" />
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource SurfaceSunken}"
                                                    Stroke="{StaticResource Border}"
                                                    StrokeShape="RoundRectangle 12"
                                                    HeightRequest="38"
                                                    VerticalOptions="Center">
                                                <Grid ColumnDefinitions="30,*,30">
                                                    <Label Grid.Column="0"
                                                           Text="-"
                                                           FontSize="18"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.QuitarDelCarritoCommand}"
                                                                CommandParameter="{Binding .}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Cantidad}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="2"
                                                           Text="+"
                                                           FontSize="18"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource Primary}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AgregarAlCarritoCommand}"
                                                                CommandParameter="{Binding Producto}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    BackgroundColor="{StaticResource DangerLight}"
                                                    Stroke="Transparent"
                                                    StrokeShape="RoundRectangle 10"
                                                    HeightRequest="34"
                                                    WidthRequest="34"
                                                    VerticalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarItemCarritoCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="X"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Danger}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>

                        <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0"
                                HeightRequest="48">
                            <Entry Text="{Binding Observaciones}"
                                   Placeholder="Observaciones del pedido..."
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Grid.Column="1"
                                   Text="{Binding TotalTexto}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                        </Grid>

                        <Button Text="ENVIAR A COCINA"
                                Command="{Binding EnviarACocinaCommand}"
                                IsVisible="{Binding PuedeEnviarACocina}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource BtnPrimary}"
                                HeightRequest="56"
                                FontSize="16" />

                        <Border IsVisible="{Binding MostrarPedidoEnPreparacion}"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                Stroke="{StaticResource PrimarySoft}"
                                StrokeShape="RoundRectangle 14"
                                Padding="14,12">
                            <Label Text="Pedido en preparación"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                        <Button Text="ENTREGAR PEDIDO"
                                Command="{Binding EntregarPedidoActualCommand}"
                                IsVisible="{Binding PuedeEntregarPedido}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource BtnPrimary}"
                                HeightRequest="56"
                                FontSize="16" />

                        <Button Text="COBRAR CUENTA"
                                Command="{Binding CobrarCuentaCommand}"
                                IsVisible="{Binding PuedeCobrarCuenta}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource BtnPrimary}"
                                HeightRequest="56"
                                FontSize="16" />

                        <Button Text="CERRAR MESA"
                                Command="{Binding CerrarMesaCommand}"
                                IsVisible="{Binding PuedeCerrarMesa}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource BtnPrimary}"
                                HeightRequest="56"
                                FontSize="16" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                              IsVisible="{Binding PuedeGuardarBorrador}">
                            <Button Text="Guardar"
                                    Command="{Binding EnviarPedidoCommand}"
                                    Style="{StaticResource BtnSecondary}"
                                    HeightRequest="46"
                                    FontSize="14" />
                            <Button Grid.Column="1"
                                    Text="Cancelar"
                                    Command="{Binding LimpiarCarritoCommand}"
                                    Style="{StaticResource BtnDanger}"
                                    HeightRequest="46"
                                    FontSize="14" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>

        </Grid>

        <!-- ══ BOTTOM SHEET CLIENTE ══ -->
        <Grid IsVisible="{Binding MostrarClienteSheet}">
            <BoxView Color="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CerrarClienteSheetCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border VerticalOptions="End"
                    BackgroundColor="White"
                    Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="16,12,16,24">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,-4" Radius="20" Opacity="0.12" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">
                    <BoxView WidthRequest="40"
                             HeightRequest="4"
                             CornerRadius="2"
                             Color="{StaticResource Border}"
                             HorizontalOptions="Center" />

                    <Grid ColumnDefinitions="*,40">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Cliente del pedido"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Busca por cedula, nombre o telefono"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="40"
                                WidthRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CerrarClienteSheetCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="X"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <Label Text="{Binding ClienteSheetMensaje}"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Danger}"
                           IsVisible="{Binding ClienteSheetMensaje, Converter={StaticResource StringToBoolConverter}}" />

                    <!-- Busqueda y resultados -->
                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding MostrandoCrearCliente, Converter={StaticResource InvertBoolConverter}}">
                        <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0"
                                HeightRequest="48">
                            <Entry Text="{Binding BusquedaCliente}"
                                   Placeholder="Cedula/RUC, nombre o telefono..."
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />
                        </Border>

                        <ActivityIndicator IsRunning="{Binding IsBuscandoClientes}"
                                           IsVisible="{Binding IsBuscandoClientes}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />

                        <CollectionView ItemsSource="{Binding ClientesEncontrados}"
                                        SelectionMode="None"
                                        MaximumHeightRequest="300">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ClienteResponse">
                                    <Border BackgroundColor="White"
                                            Stroke="{StaticResource Border}"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SeleccionarClienteCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Nombre}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Cedula}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}" />
                                                <Label Text="{Binding Telefono}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextMuted}"
                                                       IsVisible="{Binding Telefono, Converter={StaticResource StringToBoolConverter}}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1"
                                                   Text="+"
                                                   FontSize="24"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Primary}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <VerticalStackLayout IsVisible="{Binding MostrarClienteVacio}"
                                             Spacing="12"
                                             Padding="0,18"
                                             HorizontalOptions="Center">
                            <Label Text="No se encontraron clientes"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center" />
                            <Button Text="CREAR CLIENTE"
                                    Command="{Binding MostrarCrearClienteCommand}"
                                    Style="{StaticResource BtnPrimary}"
                                    HeightRequest="48"
                                    Padding="22,0" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Crear cliente rapido -->
                    <VerticalStackLayout Spacing="10"
                                         IsVisible="{Binding MostrandoCrearCliente}">
                        <Entry Text="{Binding ClienteNuevoNombre}"
                               Placeholder="Nombre completo"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="{StaticResource SurfaceSunken}" />
                        <Entry Text="{Binding ClienteNuevoCedula}"
                               Placeholder="Cedula/RUC opcional"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               Keyboard="Numeric"
                               BackgroundColor="{StaticResource SurfaceSunken}" />
                        <Entry Text="{Binding ClienteNuevoTelefono}"
                               Placeholder="Telefono opcional"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               Keyboard="Telephone"
                               BackgroundColor="{StaticResource SurfaceSunken}" />
                        <Entry Text="{Binding ClienteNuevoEmail}"
                               Placeholder="Correo opcional"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               Keyboard="Email"
                               BackgroundColor="{StaticResource SurfaceSunken}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                            <Button Text="VOLVER"
                                    Command="{Binding BuscarClienteCommand}"
                                    Style="{StaticResource BtnSecondary}"
                                    HeightRequest="48" />
                            <Button Grid.Column="1"
                                    Text="GUARDAR"
                                    Command="{Binding CrearClienteRapidoCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                    Style="{StaticResource BtnPrimary}"
                                    HeightRequest="48" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══ TOAST ══ -->
        <Border IsVisible="{Binding MostrarMensaje}"
                VerticalOptions="End"
                Margin="16,0,16,32"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="1.5"
                Padding="14,12">
            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding MensajeEsError}" Value="True">
                    <Setter Property="BackgroundColor" Value="{StaticResource DangerLight}" />
                    <Setter Property="Stroke" Value="{StaticResource Danger}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding MensajeEsError}" Value="False">
                    <Setter Property="BackgroundColor" Value="{StaticResource SuccessLight}" />
                    <Setter Property="Stroke" Value="{StaticResource Success}" />
                </DataTrigger>
            </Border.Triggers>
            <Label Text="{Binding Mensaje}"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
        </Border>

        <!-- ══ PANTALLA DE ÉXITO ══ -->
        <Grid RowDefinitions="*,Auto"
              BackgroundColor="{StaticResource Surface}"
              IsVisible="{Binding MostrarExito}">

            <VerticalStackLayout Grid.Row="0"
                                 Spacing="16"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Padding="32">

                <!-- Icono check animado -->
                <Border BackgroundColor="{StaticResource SuccessLight}"
                        StrokeShape="RoundRectangle 64"
                        Stroke="Transparent"
                        WidthRequest="120" HeightRequest="120"
                        HorizontalOptions="Center">
                    <Label Text="✓"
                           FontSize="60"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Success}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <Label Text="¡Pedido enviado!"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Label Text="La cocina ha recibido el pedido."
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <!-- Resumen del pedido -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 18"
                        Padding="18,14"
                        Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="10">
                        <Label Text="Total"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Grid.Column="1"
                               Text="{Binding PedidoEntregadoTotalTexto}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                        <Label Grid.Row="1"
                               Text="Mesa"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding MesaNumeroTexto}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!-- Acciones post-éxito -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="10"
                                 Padding="16,0,16,40">
                <Button Text="IMPRIMIR CUENTA"
                        Style="{StaticResource BtnSecondary}"
                        HeightRequest="52"
                        Command="{Binding ImprimirCuentaCommand}" />
                <Button Text="CERRAR MESA"
                        Style="{StaticResource BtnPrimary}"
                        HeightRequest="56"
                        Command="{Binding CerrarMesaCommand}" />
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>
