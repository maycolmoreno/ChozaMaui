<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.PosPage"
             x:Name="PosPageRoot"
             x:DataType="vm:PosViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="True"
             BackgroundColor="{StaticResource Surface}">

    <Grid>

        <!-- ══ VISTA PRINCIPAL ══ -->
        <Grid RowDefinitions="Auto,*"
              IsVisible="{Binding MostrarExito, Converter={StaticResource InvertBoolConverter}}">

            <controls:PosHeaderView Grid.Row="0"
                                    MostrarVolver="True"
                                    BackCommand="{Binding VolverCommand}"
                                    InicialesUsuario="{Binding InicialesUsuario}"
                                    NombreUsuario="{Binding NombreUsuarioHeader}"
                                    RolUsuario="{Binding RolUsuarioHeader}"
                                    Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                                    Kpi1Valor="{Binding HeaderKpi1Valor}"
                                    Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                                    Kpi2Valor="{Binding HeaderKpi2Valor}"
                                    Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                                    Kpi3Valor="{Binding HeaderKpi3Valor}"
                                    TotalAlertas="{Binding TotalAlertasHeader}"
                                    NotificacionesCommand="{Binding IrNotificacionesCommand}"
                                    RefreshCommand="{Binding CargarDatosCommand}" />

            <!-- ── SCROLL DE CONTENIDO ── -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding ProductosFiltrados}"
                            ItemsUpdatingScrollMode="KeepScrollOffset"
                            ItemSizingStrategy="MeasureFirstItem"
                            RemainingItemsThreshold="8"
                            RemainingItemsThresholdReachedCommand="{Binding CargarMasProductosCommand}"
                            SelectionMode="None"
                            Margin="16,0,16,92">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <VerticalStackLayout Padding="0,14,0,10" Spacing="16">

                    <!-- Alerta pedido listo (banner top) -->
                    <Border BackgroundColor="{StaticResource WarningLight}"
                            Stroke="{StaticResource Warning}"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,10"
                            IsVisible="{Binding MostrarPedidoListo}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Text="!"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryPressed}"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="¡Pedido listo para entregar!"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PrimaryPressed}" />
                                <Label Text="{Binding MesaNumeroTexto}"
                                       FontSize="12"
                                       TextColor="{StaticResource PrimaryPressed}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="Ver"
                                    Command="{Binding VerDetallePedidoCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Padding="4,0" />
                        </Grid>
                    </Border>

                    <!-- ── BUSCAR PRODUCTO ── -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0"
                                HeightRequest="50">
                            <Grid>
                                <Entry Text="{Binding BusquedaProducto}"
                                       Placeholder="Buscar producto..."
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                        <Border Grid.Column="1"
                                BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="50" WidthRequest="48">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding MostrarTodosCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="☰"
                                   FontSize="18"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- ── CATEGORÍAS ── -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="8">
                            <!-- Todos -->
                            <Border BackgroundColor="{StaticResource Primary}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="14,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MostrarTodosCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="Todos"
                                       TextColor="White"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                            </Border>

                            <HorizontalStackLayout Spacing="8"
                                                   BindableLayout.ItemsSource="{Binding Categorias}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:CategoriaResponse">
                                        <Border BackgroundColor="White"
                                                Stroke="{StaticResource Border}"
                                                StrokeShape="RoundRectangle 20"
                                                Padding="14,8">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference PosPageRoot}, Path=BindingContext.FiltrarPorCategoriaCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            <Label Text="{Binding Nombre}"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontAttributes="Bold" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- ── SECCIÓN PRODUCTOS ── -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Productos"
                               Style="{StaticResource SectionTitle}"
                               VerticalOptions="Center" />
                        <ActivityIndicator Grid.Column="1"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="22" WidthRequest="22" />
                    </Grid>

                    </VerticalStackLayout>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProductoResponse">
                                <Border BackgroundColor="White"
                                        Stroke="{StaticResource Border}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8"
                                        HeightRequest="160">
                                    <Grid RowDefinitions="60,*,Auto" RowSpacing="5">

                                        <Border Grid.Row="0"
                                                BackgroundColor="{StaticResource SurfaceSunken}"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 10"
                                                HeightRequest="60">
                                            <Grid>
                                                <Image Source="utensils.svg"
                                                       WidthRequest="18"
                                                       HeightRequest="18"
                                                       Opacity="0.45"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       IsVisible="{Binding TieneImagenMenu, Converter={StaticResource InvertBoolConverter}}" />
                                                <Image Source="{Binding ImagenMenuSource}"
                                                       Aspect="AspectFit"
                                                       HeightRequest="60"
                                                       HorizontalOptions="Fill"
                                                       VerticalOptions="Fill"
                                                       IsVisible="{Binding TieneImagenMenu}" />
                                            </Grid>
                                        </Border>

                                        <!-- Nombre -->
                                        <Label Grid.Row="1"
                                               Text="{Binding Nombre}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />

                                        <!-- Precio + botón agregar -->
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Precio, StringFormat='${0:0.##}'}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Primary}"
                                                   VerticalOptions="Center" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource PrimaryLight}"
                                                    StrokeShape="RoundRectangle 10"
                                                    Stroke="Transparent"
                                                    HeightRequest="34" WidthRequest="34">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference PosPageRoot}, Path=BindingContext.AgregarAlCarritoCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="+"
                                                       FontSize="20"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>

                                    </Grid>
                                </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="18" Color="Transparent" />
                </CollectionView.Footer>
            </CollectionView>

            <!-- ── CARRITO FIJO ── -->
            <Border Grid.Row="1"
                    IsVisible="{Binding MostrarCarritoFijo}"
                    VerticalOptions="End"
                    Margin="12,0,12,10"
                    BackgroundColor="White"
                    Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 18"
                    Padding="12">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.14" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="6">
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10">
                        <Label Text="{Binding CarritoItemsTexto}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding EstadoPedidoTexto}"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding TotalTexto}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding ObservacionesResumenTexto}"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Text="VER PEDIDO"
                            Command="{Binding VerPedidoCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="14"
                            HeightRequest="40"
                            Padding="16,0"
                            FontSize="12"
                            FontAttributes="Bold" />
                </Grid>
            </Border>

        </Grid>

        <!-- ══ CONTENEDOR SHEET PEDIDO (lazy) ══ -->
        <Grid x:Name="PedidoSheetContainer"
              IsVisible="{Binding MostrarPedidoSheet}" />

        <!-- ══ CONTENEDOR SHEET CLIENTE (lazy) ══ -->
        <Grid x:Name="ClienteSheetContainer"
              IsVisible="{Binding MostrarClienteSheet}" />

        <!-- ══ TOAST ══ -->
        <Border IsVisible="{Binding MostrarMensaje}"
                VerticalOptions="End"
                Margin="16,0,16,32"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="1.5"
                Padding="14,12">
            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding MensajeEsError}" Value="True">
                    <Setter Property="BackgroundColor" Value="{StaticResource DangerLight}" />
                    <Setter Property="Stroke" Value="{StaticResource Danger}" />
                </DataTrigger>
                <DataTrigger TargetType="Border" Binding="{Binding MensajeEsError}" Value="False">
                    <Setter Property="BackgroundColor" Value="{StaticResource SuccessLight}" />
                    <Setter Property="Stroke" Value="{StaticResource Success}" />
                </DataTrigger>
            </Border.Triggers>
            <Label Text="{Binding Mensaje}"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
        </Border>

        <!-- ══ CONTENEDOR ÉXITO (lazy) ══ -->
        <Grid x:Name="ExitoContainer"
              IsVisible="{Binding MostrarExito}" />

    </Grid>
</ContentPage>
