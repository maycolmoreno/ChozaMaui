<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChozaMaui.Views.Controls.ConnectivityActionsView"
             x:Name="Root">

    <HorizontalStackLayout Spacing="8">

        <Grid>
            <Border BackgroundColor="{Binding Connectivity.StatusColor, Source={x:Reference Root}}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 12"
                    HeightRequest="40"
                    WidthRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVerifyTapped" />
                </Border.GestureRecognizers>
                <Label Text="●"
                       FontSize="16"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <ActivityIndicator IsRunning="{Binding Connectivity.IsChecking, Source={x:Reference Root}}"
                               IsVisible="{Binding Connectivity.IsChecking, Source={x:Reference Root}}"
                               Color="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>

        <Border BackgroundColor="#FB923C"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 12"
                HeightRequest="40"
                WidthRequest="40"
                IsVisible="{Binding HasRefreshCommand, Source={x:Reference Root}}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRefreshTapped" />
            </Border.GestureRecognizers>
            <Label Text="↻"
                   FontSize="20"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>

    </HorizontalStackLayout>
</ContentView>