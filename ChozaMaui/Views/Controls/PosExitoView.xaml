<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             x:Class="ChozaMaui.Views.Controls.PosExitoView"
             x:DataType="vm:PosViewModel">

    <Grid RowDefinitions="*,Auto"
          BackgroundColor="{StaticResource Surface}">

        <!-- Contenido central -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="16"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="32">

            <!-- Icono check -->
            <Border BackgroundColor="{StaticResource SuccessLight}"
                    StrokeShape="RoundRectangle 64"
                    Stroke="Transparent"
                    WidthRequest="120" HeightRequest="120"
                    HorizontalOptions="Center">
                <Label Text="✓"
                       FontSize="60"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Success}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Text="¡Pedido enviado!"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="La cocina ha recibido el pedido."
                   FontSize="14"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Resumen -->
            <Border BackgroundColor="White"
                    Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 18"
                    Padding="18,14"
                    Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="10">
                    <Label Text="Total"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Grid.Column="1"
                           Text="{Binding PedidoEntregadoTotalTexto}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}" />
                    <Label Grid.Row="1"
                           Text="Mesa"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding MesaNumeroTexto}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- Acciones post-éxito -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="10"
                             Padding="16,0,16,40">
            <Button Text="IMPRIMIR CUENTA"
                    Style="{StaticResource BtnSecondary}"
                    HeightRequest="52"
                    Command="{Binding ImprimirCuentaCommand}" />
            <Button Text="CERRAR MESA"
                    Style="{StaticResource BtnPrimary}"
                    HeightRequest="56"
                    Command="{Binding CerrarMesaCommand}" />
        </VerticalStackLayout>

    </Grid>
</ContentView>
