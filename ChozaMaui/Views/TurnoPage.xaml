<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.TurnoPage"
             x:DataType="vm:TurnoViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource Orange}"
              Padding="14,44,14,14"
              ColumnDefinitions="Auto,*,Auto">
            <Image Grid.Column="0"
                   Source="lachozalogo.png"
                   HeightRequest="38"
                   WidthRequest="38"
                   Aspect="AspectFit"
                   VerticalOptions="Center"
                   Margin="0,0,10,0" />

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="1"
                                 VerticalOptions="Center">
                <Label Text="Turno de caja"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="{Binding NombreUsuario}"
                       FontSize="12"
                       TextColor="#FFE3D0" />
            </VerticalStackLayout>

            <controls:ConnectivityActionsView Grid.Column="2"
                                              RefreshCommand="{Binding CargarCommand}"
                                              HorizontalOptions="End"
                                              VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,12,14,30"
                                 Spacing="12">

                <Border BackgroundColor="White"
                        Stroke="#E5E7EB"
                        StrokeShape="RoundRectangle 14"
                        Padding="14">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="2">
                                <Label Text="{Binding EstadoCajaTexto}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding NumeroCajaTexto}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    Padding="9,4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    VerticalOptions="Start"
                                    BackgroundColor="{Binding EstadoCajaTexto,
                                        Converter={StaticResource StringEqualsColorConverter},
                                        ConverterParameter='Abierta|#16a34a|#dc2626'}">
                                <Label Text="{Binding EstadoCajaTexto}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="2">
                                <Label Text="Apertura"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding HoraAperturaTexto}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Fondo inicial"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding FondoInicialTexto}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              IsVisible="{Binding PuedeGestionarCaja}">
                            <Button Grid.Column="0"
                                    Text="Abrir caja"
                                    Command="{Binding ToggleFormAperturaCommand}"
                                    IsVisible="{Binding TieneTurnoAbierto, Converter={StaticResource InvertBoolConverter}}"
                                    BackgroundColor="{StaticResource Orange}"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    FontAttributes="Bold" />

                            <Button Grid.Column="0"
                                    Text="Cerrar caja"
                                    Command="{Binding ToggleFormCierreCommand}"
                                    IsVisible="{Binding TieneTurnoAbierto}"
                                    BackgroundColor="#EF4444"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    FontAttributes="Bold" />

                            <Border Grid.Column="1"
                                    BackgroundColor="#F9FAFB"
                                    Stroke="#E5E7EB"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,8">
                                <VerticalStackLayout Spacing="1"
                                                     HorizontalOptions="Center">
                                    <Label Text="{Binding CuentasPendientes.Count}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Orange}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="por cobrar"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="#FFF7ED"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="12"
                                IsVisible="{Binding MostrarFormApertura}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Monto inicial"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Entry Placeholder="0.00"
                                       Text="{Binding MontoInicial}"
                                       Keyboard="Numeric"
                                       BackgroundColor="White"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Button Text="Confirmar apertura"
                                        Command="{Binding AbrirTurnoCommand}"
                                        BackgroundColor="{StaticResource Orange}"
                                        TextColor="White"
                                        CornerRadius="10" />
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="#FEF2F2"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="12"
                                IsVisible="{Binding MostrarFormCierre}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Efectivo contado"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Entry Placeholder="0.00"
                                       Text="{Binding MontoFinal}"
                                       Keyboard="Numeric"
                                       BackgroundColor="White"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Button Text="Confirmar cierre"
                                        Command="{Binding CerrarTurnoCommand}"
                                        BackgroundColor="#EF4444"
                                        TextColor="White"
                                        CornerRadius="10" />
                            </VerticalStackLayout>
                        </Border>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Orange}"
                                           HorizontalOptions="Center" />

                        <Label Text="{Binding Mensaje}"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"
                               IsVisible="{Binding Mensaje, Converter={StaticResource NotNullToBoolConverter}}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#E5E7EB"
                        StrokeShape="RoundRectangle 14"
                        Padding="14"
                        IsVisible="{Binding TieneTurnoAbierto}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Registrar pago"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Border BackgroundColor="#F9FAFB"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 10"
                                Padding="4,0">
                            <Picker ItemsSource="{Binding CuentasPendientes}"
                                    SelectedItem="{Binding CuentaSeleccionada}"
                                    ItemDisplayBinding="{Binding MesaTexto}"
                                    Title="Cuenta a cobrar"
                                    TitleColor="#9CA3AF"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="Transparent" />
                        </Border>

                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding TieneCuentaSeleccionada}">
                            <Label Grid.Column="0"
                                   Text="Total"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding TotalCuentaTexto}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Orange}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="Efectivo"
                                    Command="{Binding SeleccionarMetodoPagoCommand}"
                                    CommandParameter="EFECTIVO"
                                    BackgroundColor="{Binding EsMetodoEfectivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFF7ED|#F9FAFB'}"
                                    BorderColor="{Binding EsMetodoEfectivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F97316|#E5E7EB'}"
                                    BorderWidth="1"
                                    TextColor="{Binding EsMetodoEfectivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F97316|#667085'}"
                                    CornerRadius="10"
                                    HeightRequest="42" />

                            <Button Grid.Column="1"
                                    Text="Tarjeta"
                                    Command="{Binding SeleccionarMetodoPagoCommand}"
                                    CommandParameter="TARJETA"
                                    BackgroundColor="{Binding EsMetodoTarjeta, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EFF6FF|#F9FAFB'}"
                                    BorderColor="{Binding EsMetodoTarjeta, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#E5E7EB'}"
                                    BorderWidth="1"
                                    TextColor="{Binding EsMetodoTarjeta, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#667085'}"
                                    CornerRadius="10"
                                    HeightRequest="42" />

                            <Button Grid.Column="2"
                                    Text="Transfer."
                                    Command="{Binding SeleccionarMetodoPagoCommand}"
                                    CommandParameter="TRANSFERENCIA"
                                    BackgroundColor="{Binding EsMetodoTransferencia, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FDF4FF|#F9FAFB'}"
                                    BorderColor="{Binding EsMetodoTransferencia, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#9333EA|#E5E7EB'}"
                                    BorderWidth="1"
                                    TextColor="{Binding EsMetodoTransferencia, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#9333EA|#667085'}"
                                    CornerRadius="10"
                                    HeightRequest="42" />
                        </Grid>

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding EsMetodoEfectivo}">
                            <Label Text="Efectivo recibido"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Entry Placeholder="0.00"
                                   Keyboard="Numeric"
                                   Text="{Binding MontoRecibido}"
                                   BackgroundColor="#F9FAFB"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding HayCambio}">
                            <Label Grid.Column="0"
                                   Text="Cambio"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding CambioCalculado, StringFormat='${0:0.00}'}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#16A34A" />
                        </Grid>

                        <Label Text="{Binding MensajePago}"
                               FontSize="12"
                               TextColor="{StaticResource Danger}"
                               IsVisible="{Binding MensajePago, Converter={StaticResource NotNullToBoolConverter}}" />

                        <Border BackgroundColor="#F0FDF4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,8"
                                IsVisible="{Binding PagoRegistradoOk}">
                            <Label Text="Pago registrado correctamente"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#16A34A"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                        <Button Text="Confirmar pago"
                                Command="{Binding RegistrarPagoRapidoCommand}"
                                IsEnabled="{Binding TieneCuentaSeleccionada}"
                                BackgroundColor="{StaticResource Orange}"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="48"
                                FontAttributes="Bold"
                                FontSize="15" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#E5E7EB"
                        StrokeShape="RoundRectangle 14"
                        Padding="14"
                        IsVisible="{Binding TieneTurnoAbierto}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="Pagos de esta sesion"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    BackgroundColor="#F3F4F6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="8,4">
                                <Label Text="{Binding HistorialPagos.Count}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding HistorialPagos}">
                            <BindableLayout.EmptyView>
                                <Label Text="Sin pagos registrados en esta sesion"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,8,0,0" />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:PagoResponse">
                                    <Grid Padding="0,6"
                                          ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="1">
                                            <Label Text="{Binding Metodo}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding Fecha, StringFormat='{0:HH:mm · dd/MM}'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding Monto, StringFormat='${0:0.00}'}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="#16A34A"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
