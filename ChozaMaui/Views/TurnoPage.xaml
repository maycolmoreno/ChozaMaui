<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             x:Class="ChozaMaui.Views.TurnoPage"
             x:DataType="vm:TurnoViewModel"
             Title="Turnos"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header naranja -->
            <Grid BackgroundColor="{StaticResource Orange}" Padding="16,48,16,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="lachozalogo.png"
                       HeightRequest="44" WidthRequest="44"
                       Aspect="AspectFit"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Gestión de Turnos"
                           FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Administra la apertura y cierre de caja"
                           FontSize="13" TextColor="#ffe0b2" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Banner turno activo -->
                <Frame IsVisible="{Binding TieneTurnoAbierto}"
                       BackgroundColor="{StaticResource OrangeLight}"
                       BorderColor="{StaticResource Orange}"
                       CornerRadius="10" Padding="14" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🔓" FontSize="24" VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Turno Activo" FontAttributes="Bold"
                                   TextColor="{StaticResource Orange}" FontSize="15" />
                            <Label Text="{Binding TurnoActivo.FechaApertura, StringFormat='Abierto: {0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="13" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding TurnoActivo.MontoInicial, StringFormat='Efectivo inicial: ${0:F2}'}"
                                   FontSize="13" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding TurnoActivo.UsuarioApertura, StringFormat='Apertura por: {0}'}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- ── Abrir Turno ── -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="16" HasShadow="False"
                       Opacity="{Binding TieneTurnoAbierto, Converter={StaticResource InvertBoolConverter}}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Abrir Turno" FontAttributes="Bold"
                               FontSize="18" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Declara la cantidad inicial de efectivo para abrir tu turno."
                               FontSize="13" TextColor="{StaticResource TextSecondary}" />

                        <Border BackgroundColor="{StaticResource Gray100}"
                                StrokeShape="RoundRectangle 8" Stroke="#e5e7eb" Padding="12,8">
                            <Entry Placeholder="Cantidad inicial de efectivo"
                                   Text="{Binding MontoInicial}"
                                   Keyboard="Numeric"
                                   PlaceholderColor="#9ca3af"
                                   TextColor="{StaticResource TextPrimary}"
                                   IsEnabled="{Binding TieneTurnoAbierto, Converter={StaticResource InvertBoolConverter}}"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Button Text="Abrir Turno"
                                Command="{Binding AbrirTurnoCommand}"
                                BackgroundColor="{StaticResource Orange}"
                                TextColor="White" CornerRadius="8" FontAttributes="Bold"
                                HeightRequest="46"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Cerrar Turno ── -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="16" HasShadow="False"
                       Opacity="{Binding TieneTurnoAbierto}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Cerrar Turno" FontAttributes="Bold"
                               FontSize="18" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Declara la cantidad final de efectivo para cerrar tu turno."
                               FontSize="13" TextColor="{StaticResource TextSecondary}" />

                        <Border BackgroundColor="{StaticResource Gray100}"
                                StrokeShape="RoundRectangle 8" Stroke="#e5e7eb" Padding="12,8">
                            <Entry Placeholder="Cantidad final de efectivo"
                                   Text="{Binding MontoFinal}"
                                   Keyboard="Numeric"
                                   PlaceholderColor="#9ca3af"
                                   TextColor="{StaticResource TextPrimary}"
                                   IsEnabled="{Binding TieneTurnoAbierto}"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <Button Text="Cerrar Turno"
                                Command="{Binding CerrarTurnoCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White" CornerRadius="8" FontAttributes="Bold"
                                HeightRequest="46"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Mensaje de resultado -->
                <Label Text="{Binding Mensaje}"
                       FontSize="13" TextColor="{StaticResource Orange}"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}" />

                <!-- Indicador de carga -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Orange}"
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
