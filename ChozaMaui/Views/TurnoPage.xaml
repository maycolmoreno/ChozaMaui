<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.TurnoPage"
             x:DataType="vm:TurnoViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="Auto,*">
        <controls:PosHeaderView Grid.Row="0"
                                InicialesUsuario="{Binding InicialesUsuario}"
                                NombreUsuario="{Binding NombreUsuario}"
                                RolUsuario="{Binding RolUsuarioHeader}"
                                Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                                Kpi1Valor="{Binding HeaderKpi1Valor}"
                                Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                                Kpi2Valor="{Binding HeaderKpi2Valor}"
                                Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                                Kpi3Valor="{Binding HeaderKpi3Valor}"
                                TotalAlertas="{Binding TotalAlertasHeader}"
                                NotificacionesCommand="{Binding IrNotificacionesCommand}"
                                RefreshCommand="{Binding CargarCommand}" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,12,14,30"
                                 Spacing="12">

                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 14"
                        Padding="14">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="2">
                                <Label Text="{Binding EstadoCajaTexto}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding NumeroCajaTexto}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    Padding="9,4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    VerticalOptions="Start"
                                    BackgroundColor="{Binding EstadoCajaTexto,
                                        Converter={StaticResource StringEqualsColorConverter},
                                        ConverterParameter='Abierta|#16A34A|#DC2626'}">
                                <Label Text="{Binding EstadoCajaTexto}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="2">
                                <Label Text="Apertura"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding HoraAperturaTexto}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Fondo inicial"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding FondoInicialTexto}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              IsVisible="{Binding PuedeMostrarAccionesCaja}">
                            <Button Grid.Column="0"
                                    Text="Abrir caja"
                                    Command="{Binding ToggleFormAperturaCommand}"
                                    IsVisible="{Binding TieneTurnoAbierto, Converter={StaticResource InvertBoolConverter}}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    FontAttributes="Bold" />

                            <Button Grid.Column="0"
                                    Text="Cerrar caja"
                                    Command="{Binding ToggleFormCierreCommand}"
                                    IsVisible="{Binding TieneTurnoAbierto}"
                                    BackgroundColor="{StaticResource Danger}"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    FontAttributes="Bold" />

                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource SurfaceSunken}"
                                    Stroke="{StaticResource Border}"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,8">
                                <VerticalStackLayout Spacing="1"
                                                     HorizontalOptions="Center">
                                    <Label Text="{Binding HistorialPagos.Count}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="pagos"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="12"
                                IsVisible="{Binding MostrarFormApertura}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Monto inicial"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Entry Placeholder="0.00"
                                       Text="{Binding MontoInicial}"
                                       Keyboard="Numeric"
                                       BackgroundColor="{StaticResource SurfaceCard}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Button Text="Confirmar apertura"
                                        Command="{Binding AbrirTurnoCommand}"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        CornerRadius="10" />
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="{StaticResource DangerLight}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="12"
                                IsVisible="{Binding MostrarFormCierre}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Efectivo contado"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Entry Placeholder="0.00"
                                       Text="{Binding MontoFinal}"
                                       Keyboard="Numeric"
                                       BackgroundColor="{StaticResource SurfaceCard}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Button Text="Confirmar cierre"
                                        Command="{Binding CerrarTurnoCommand}"
                                        BackgroundColor="{StaticResource Danger}"
                                        TextColor="White"
                                        CornerRadius="10" />
                            </VerticalStackLayout>
                        </Border>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />

                        <Label Text="{Binding Mensaje}"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}"
                               IsVisible="{Binding Mensaje, Converter={StaticResource NotNullToBoolConverter}}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 14"
                        Padding="14"
                        IsVisible="{Binding TieneTurnoAbierto}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="Pagos de esta sesion"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource SurfaceSunken}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="8,4">
                                <Label Text="{Binding TotalPagosTurnoTexto}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding HistorialPagos}">
                            <BindableLayout.EmptyView>
                                <Label Text="Sin pagos registrados en esta sesion"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,8,0,0" />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:PagoResponse">
                                    <Grid Padding="0,6"
                                          ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="1">
                                            <Label Text="{Binding Metodo}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding Fecha, StringFormat='{0:HH:mm · dd/MM}'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding Monto, StringFormat='${0:0.00}'}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Success}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
