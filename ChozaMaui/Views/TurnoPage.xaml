<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:conv="clr-namespace:ChozaMaui.Converters"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.TurnoPage"
             x:DataType="vm:TurnoViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══════════════════════════════════════ HEADER NARANJA -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Orange}" Padding="14,44,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="lachozalogo.png"
                   HeightRequest="38" WidthRequest="38" Aspect="AspectFit"
                   VerticalOptions="Center" Margin="0,0,10,0" />

            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="Choza POS · Cajero"
                       FontSize="17" FontAttributes="Bold" TextColor="White" />
                <Label Text="{Binding NombreUsuario}"
                       FontSize="12" TextColor="#FFE3D0" />
            </VerticalStackLayout>

            <controls:ConnectivityActionsView Grid.Column="2"
                                              Grid.ColumnSpan="2"
                                              RefreshCommand="{Binding CargarCommand}"
                                              HorizontalOptions="End"
                                              VerticalOptions="Center" />
        </Grid>

        <!-- ═══════════════════════════════════════ SPLIT PANEL -->
        <Grid Grid.Row="1" ColumnDefinitions="260,*">

            <!-- ══════════════════ PANEL IZQUIERDO (OSCURO) -->
            <Grid Grid.Column="0" BackgroundColor="#1e2028"
                  RowDefinitions="Auto,*,Auto,*">
                <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="10,12,10,0">

                        <!-- ESTADO DE CAJA -->
                        <Border BackgroundColor="#252836" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" Padding="14" Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="8">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="Estado de caja"
                                           FontSize="13" FontAttributes="Bold" TextColor="White"
                                           VerticalOptions="Center" />
                                    <Border Grid.Column="1" Padding="7,3" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 6"
                                            BackgroundColor="{Binding EstadoCajaTexto,
                                                Converter={StaticResource StringEqualsColorConverter},
                                                ConverterParameter='Abierta|#16a34a|#dc2626'}">
                                        <Label Text="{Binding EstadoCajaTexto}"
                                               FontSize="11" FontAttributes="Bold" TextColor="White" />
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="[T]" FontSize="12"
                                           TextColor="#aab0bd" Margin="0,0,6,0" />
                                    <Label Grid.Column="1" Text="{Binding HoraAperturaTexto}"
                                           FontSize="12" TextColor="#aab0bd" VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="$" FontSize="13"
                                           TextColor="{StaticResource Orange}" FontAttributes="Bold"
                                           Margin="0,0,6,0" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding FondoInicialTexto}"
                                           FontSize="12" TextColor="#aab0bd" VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding NumeroCajaTexto}"
                                           FontSize="12" TextColor="#aab0bd" VerticalOptions="Center" />
                                    <Border Grid.Column="1" BackgroundColor="{StaticResource Orange}"
                                            Padding="6,2" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 6"
                                            IsVisible="{Binding TieneTurnoAbierto}">
                                        <Label Text="En turno" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                    </Border>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                        <!-- ACCIONES CAJA 2x2 -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                              ColumnSpacing="8" RowSpacing="8" Margin="0,0,0,12">

                            <!-- Arqueo -->
                            <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#252836"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="[Arq]" FontSize="18" TextColor="#aab0bd"
                                           HorizontalOptions="Center" />
                                    <Label Text="Arqueo" FontSize="10" TextColor="#aab0bd"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Movimientos -->
                            <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#252836"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="[Mov]" FontSize="18" TextColor="#aab0bd"
                                           HorizontalOptions="Center" />
                                    <Label Text="Movimientos" FontSize="10" TextColor="#aab0bd"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Abrir caja (cuando cerrada) -->
                            <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#252836"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10"
                                    IsVisible="{Binding TieneTurnoAbierto,
                                        Converter={StaticResource InvertBoolConverter}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleFormAperturaCommand}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="[Abr]" FontSize="18" TextColor="{StaticResource Orange}"
                                           HorizontalOptions="Center" />
                                    <Label Text="Abrir caja" FontSize="10" TextColor="{StaticResource Orange}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Cerrar caja (cuando abierta) -->
                            <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#252836"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10"
                                    IsVisible="{Binding TieneTurnoAbierto}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleFormCierreCommand}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="[Cerr]" FontSize="18" TextColor="#ef4444"
                                           HorizontalOptions="Center" />
                                    <Label Text="Cerrar caja" FontSize="10" TextColor="#ef4444"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Clientes -->
                            <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#252836"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label Text="[Cli]" FontSize="18" TextColor="#aab0bd"
                                           HorizontalOptions="Center" />
                                    <Label Text="Clientes" FontSize="10" TextColor="#aab0bd"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                        </Grid>

                        <!-- Formulario ABRIR caja -->
                        <Border BackgroundColor="#2d3148" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" Padding="12"
                                IsVisible="{Binding MostrarFormApertura}" Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Abrir caja" FontSize="13" FontAttributes="Bold" TextColor="White" />
                                <Entry Placeholder="Monto inicial ($)" PlaceholderColor="#7a8296"
                                       TextColor="White" BackgroundColor="#1e2028"
                                       Text="{Binding MontoInicial}" Keyboard="Numeric" />
                                <Button Text="Confirmar apertura" BackgroundColor="{StaticResource Orange}"
                                        TextColor="White" CornerRadius="8"
                                        Command="{Binding AbrirTurnoCommand}" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Formulario CERRAR caja -->
                        <Border BackgroundColor="#2d3148" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" Padding="12"
                                IsVisible="{Binding MostrarFormCierre}" Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Cerrar caja" FontSize="13" FontAttributes="Bold" TextColor="White" />
                                <Entry Placeholder="Efectivo contado ($)" PlaceholderColor="#7a8296"
                                       TextColor="White" BackgroundColor="#1e2028"
                                       Text="{Binding MontoFinal}" Keyboard="Numeric" />
                                <Button Text="Confirmar cierre" BackgroundColor="#ef4444"
                                        TextColor="White" CornerRadius="8"
                                        Command="{Binding CerrarTurnoCommand}" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Mensaje sistema -->
                        <Label Text="{Binding Mensaje}" FontSize="12" TextColor="#aab0bd"
                               IsVisible="{Binding Mensaje, Converter={StaticResource NotNullToBoolConverter}}"
                               HorizontalOptions="Center" Margin="0,0,0,10" />

                        <!-- CUENTAS PENDIENTES -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,8">
                            <Label Grid.Column="0" Text="Cuentas pendientes"
                                   FontSize="13" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1" BackgroundColor="{StaticResource Orange}"
                                    Padding="7,2" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="{Binding CuentasPendientes.Count}"
                                       FontSize="11" FontAttributes="Bold" TextColor="White" />
                            </Border>
                        </Grid>

                </VerticalStackLayout>
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding CuentasPendientes}"
                                ItemsUpdatingScrollMode="KeepScrollOffset"
                                Margin="10,4,10,0">
                            <CollectionView.EmptyView>
                                <Label Text="Sin cuentas abiertas" TextColor="#5a6275"
                                       FontSize="12" HorizontalOptions="Center" Margin="0,24,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:CuentaResponse">
                                    <Grid Padding="0,5" ColumnDefinitions="Auto,*,Auto">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TurnoViewModel}},
                                                    Path=SeleccionarCuentaPagoCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <!-- Circulo naranja -->
                                        <Border Grid.Column="0" BackgroundColor="{StaticResource Orange}"
                                                WidthRequest="36" HeightRequest="36"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                                Margin="0,0,8,0" VerticalOptions="Center">
                                            <Label Text="{Binding Mesa.Numero}"
                                                   FontSize="12" FontAttributes="Bold" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <!-- Info -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                            <Label Text="{Binding MesaTexto}"
                                                   FontSize="13" FontAttributes="Bold" TextColor="White" />
                                            <Label Text="{Binding Mesa.NombreComedor}"
                                                   FontSize="11" TextColor="#aab0bd" />
                                        </VerticalStackLayout>
                                        <!-- Total -->
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center"
                                                             HorizontalOptions="End" Spacing="1">
                                            <Label Text="{Binding Total, StringFormat='${0:0.00}'}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource Orange}"
                                                   HorizontalOptions="End" />
                                            <Label Text=">" FontSize="14" TextColor="#5a6275"
                                                   HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                <VerticalStackLayout Grid.Row="2" Padding="10,8,10,0">
                    <BoxView HeightRequest="1" Color="#33ffffff" />
                    <!-- HISTORIAL DE PAGOS -->
                    <Label Text="Historial de pagos"
                           FontSize="13" FontAttributes="Bold" TextColor="White"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
                <CollectionView Grid.Row="3"
                                ItemsSource="{Binding HistorialPagos}"
                                ItemsUpdatingScrollMode="KeepScrollOffset"
                                Margin="10,4,10,8">
                            <CollectionView.EmptyView>
                                <Label Text="Sin pagos en esta sesion" TextColor="#5a6275"
                                       FontSize="12" HorizontalOptions="Center" Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PagoResponse">
                                    <Grid Padding="0,5" ColumnDefinitions="Auto,*,Auto">
                                        <!-- Icono -->
                                        <Border Grid.Column="0" BackgroundColor="#252836"
                                                WidthRequest="32" HeightRequest="32"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 16"
                                                Margin="0,0,8,0" VerticalOptions="Center">
                                            <Label Text="$" FontSize="13" FontAttributes="Bold"
                                                   TextColor="#7DBE31"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <!-- Info -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                            <Label Text="{Binding Metodo}"
                                                   FontSize="12" FontAttributes="Bold" TextColor="White" />
                                            <Label Text="{Binding Fecha, StringFormat='{0:HH:mm · dd/MM}'}"
                                                   FontSize="10" TextColor="#aab0bd" />
                                        </VerticalStackLayout>
                                        <!-- Monto + badge -->
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center"
                                                             HorizontalOptions="End" Spacing="2">
                                            <Label Text="{Binding Monto, StringFormat='${0:0.00}'}"
                                                   FontSize="13" FontAttributes="Bold" TextColor="White"
                                                   HorizontalOptions="End" />
                                            <Border BackgroundColor="#16a34a" Padding="4,1"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 4">
                                                <Label Text="Pagado" FontSize="9" TextColor="White"
                                                       FontAttributes="Bold" />
                                            </Border>
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>


            </Grid>

            <!-- ══════════════════ PANEL DERECHO (CLARO) -->
            <ScrollView Grid.Column="1" BackgroundColor="#F8FAFC">
                <VerticalStackLayout Padding="14,12,14,30" Spacing="12">

                    <!-- RESUMEN DEL TURNO -->
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14" Padding="16">
                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Resumen del turno"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
                                <Border Grid.Column="1" BackgroundColor="#F3F4F6" Padding="8,4"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                    <Label Text="Hoy" FontSize="12" TextColor="#6b7280" />
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
                                  ColumnSpacing="8" RowSpacing="8">

                                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#FFF7ED"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Ventas" FontSize="11" TextColor="{StaticResource Orange}"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding MetricaVentas, StringFormat='${0:0.00}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#F0FDF4"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Pagos" FontSize="11" TextColor="#16a34a"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding MetricaPagosCount}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="2" BackgroundColor="#F0FDF4"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Efectivo" FontSize="11" TextColor="#16a34a"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding MetricaEfectivo, StringFormat='${0:0.00}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#EFF6FF"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Tarjeta" FontSize="11" TextColor="#2563eb"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding MetricaTarjeta, StringFormat='${0:0.00}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FDF4FF"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Transfer." FontSize="11" TextColor="#9333ea"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding MetricaTransferencias, StringFormat='${0:0.00}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="2" BackgroundColor="#FFFBEB"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Mixto/Otros" FontSize="11" TextColor="#d97706"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding MetricaOtros, StringFormat='${0:0.00}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                            </Grid>

                            <Label Text="{Binding AclaracionMetodosTexto}"
                                   FontSize="11"
                                   TextColor="#6b7280"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding MostrarAclaracionMetodos}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- REGISTRAR PAGO -->
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14" Padding="16">
                        <VerticalStackLayout Spacing="12">

                            <Label Text="Registrar pago" FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />

                            <!-- Selector de cuenta -->
                            <Label Text="Cuenta a cobrar" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Border BackgroundColor="#F9FAFB" StrokeThickness="1"
                                    Stroke="#E5E7EB" StrokeShape="RoundRectangle 10" Padding="4,0">
                                <Picker ItemsSource="{Binding CuentasPendientes}"
                                        SelectedItem="{Binding CuentaSeleccionada}"
                                        ItemDisplayBinding="{Binding MesaTexto}"
                                        Title="Seleccionar cuenta..."
                                        TitleColor="#9CA3AF"
                                        TextColor="{StaticResource TextPrimary}"
                                        BackgroundColor="Transparent" />
                            </Border>

                            <!-- Total a cobrar -->
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding TieneCuentaSeleccionada}">
                                <Label Grid.Column="0" Text="Total a cobrar"
                                       FontSize="13" TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding TotalCuentaTexto}"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource Orange}" />
                            </Grid>

                            <!-- Metodo de pago -->
                            <Label Text="Metodo de pago" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">

                                <!-- Efectivo -->
                                <Border Grid.Column="0" StrokeThickness="2"
                                        Stroke="#E5E7EB" StrokeShape="RoundRectangle 10" Padding="6,8"
                                        BackgroundColor="{Binding MetodoPago,
                                            Converter={StaticResource StringEqualsColorConverter},
                                            ConverterParameter='EFECTIVO|#FFF7ED|#F9FAFB'}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoPagoCommand}"
                                                              CommandParameter="EFECTIVO" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="[$]" FontSize="16" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='EFECTIVO|#F26522|#9ca3af'}" />
                                        <Label Text="Efectivo" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='EFECTIVO|#F26522|#6b7280'}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Tarjeta -->
                                <Border Grid.Column="1" StrokeThickness="2"
                                        Stroke="#E5E7EB" StrokeShape="RoundRectangle 10" Padding="6,8"
                                        BackgroundColor="{Binding MetodoPago,
                                            Converter={StaticResource StringEqualsColorConverter},
                                            ConverterParameter='TARJETA|#EFF6FF|#F9FAFB'}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoPagoCommand}"
                                                              CommandParameter="TARJETA" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="[T]" FontSize="16" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='TARJETA|#2563eb|#9ca3af'}" />
                                        <Label Text="Tarjeta" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='TARJETA|#2563eb|#6b7280'}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Transferencia -->
                                <Border Grid.Column="2" StrokeThickness="2"
                                        Stroke="#E5E7EB" StrokeShape="RoundRectangle 10" Padding="6,8"
                                        BackgroundColor="{Binding MetodoPago,
                                            Converter={StaticResource StringEqualsColorConverter},
                                            ConverterParameter='TRANSFERENCIA|#FDF4FF|#F9FAFB'}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoPagoCommand}"
                                                              CommandParameter="TRANSFERENCIA" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="[Tr]" FontSize="16" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='TRANSFERENCIA|#9333ea|#9ca3af'}" />
                                        <Label Text="Transfer." FontSize="11" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='TRANSFERENCIA|#9333ea|#6b7280'}" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Mixto -->
                                <Border Grid.Column="3" StrokeThickness="2"
                                        Stroke="#E5E7EB" StrokeShape="RoundRectangle 10" Padding="6,8"
                                        BackgroundColor="{Binding MetodoPago,
                                            Converter={StaticResource StringEqualsColorConverter},
                                            ConverterParameter='MIXTO|#FFFBEB|#F9FAFB'}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoPagoCommand}"
                                                              CommandParameter="MIXTO" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="[M]" FontSize="16" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='MIXTO|#d97706|#9ca3af'}" />
                                        <Label Text="Mixto" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{Binding MetodoPago,
                                                   Converter={StaticResource StringEqualsColorConverter},
                                                   ConverterParameter='MIXTO|#d97706|#6b7280'}" />
                                    </VerticalStackLayout>
                                </Border>

                            </Grid>

                            <!-- Efectivo recibido (solo si metodo EFECTIVO) -->
                            <VerticalStackLayout Spacing="6" IsVisible="{Binding EsMetodoEfectivo}">
                                <Label Text="Efectivo recibido ($)" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Entry Placeholder="0.00" Keyboard="Numeric"
                                       Text="{Binding MontoRecibido}"
                                       BackgroundColor="#F9FAFB"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>

                            <!-- Cambio -->
                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HayCambio}">
                                <Label Grid.Column="0" Text="Cambio" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding CambioCalculado, StringFormat='${0:0.00}'}"
                                       FontSize="20" FontAttributes="Bold" TextColor="#16a34a" />
                            </Grid>

                            <!-- Error pago -->
                            <Label Text="{Binding MensajePago}" FontSize="12"
                                   TextColor="{StaticResource Danger}"
                                   IsVisible="{Binding MensajePago,
                                       Converter={StaticResource NotNullToBoolConverter}}" />

                            <!-- Feedback OK -->
                            <Border BackgroundColor="#F0FDF4" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8" Padding="10,8"
                                    IsVisible="{Binding PagoRegistradoOk}">
                                <Label Text="Pago registrado correctamente"
                                       FontSize="13" FontAttributes="Bold" TextColor="#16a34a"
                                       HorizontalOptions="Center" />
                            </Border>

                            <!-- Boton confirmar -->
                            <Button Text="Confirmar pago"
                                    BackgroundColor="{StaticResource Orange}"
                                    TextColor="White" CornerRadius="10" HeightRequest="48"
                                    FontAttributes="Bold" FontSize="15"
                                    Command="{Binding RegistrarPagoRapidoCommand}"
                                    IsEnabled="{Binding TieneCuentaSeleccionada}" />

                        </VerticalStackLayout>
                    </Border>

                    <!-- ACCIONES RAPIDAS -->
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14" Padding="16">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="Acciones rapidas" FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                  ColumnSpacing="8" RowSpacing="8">

                                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#F9FAFB"
                                        StrokeThickness="1" Stroke="#E5E7EB"
                                        StrokeShape="RoundRectangle 10" Padding="12,10">
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="[Imp]" FontSize="20" HorizontalOptions="Center"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="Imprimir cuenta" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#F9FAFB"
                                        StrokeThickness="1" Stroke="#E5E7EB"
                                        StrokeShape="RoundRectangle 10" Padding="12,10">
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="[Pag]" FontSize="20" HorizontalOptions="Center"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="Consulta de pagos" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#F9FAFB"
                                        StrokeThickness="1" Stroke="#E5E7EB"
                                        StrokeShape="RoundRectangle 10" Padding="12,10">
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="[Cli]" FontSize="20" HorizontalOptions="Center"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="Clientes" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FFF7ED"
                                        StrokeThickness="1" Stroke="{StaticResource Orange}"
                                        StrokeShape="RoundRectangle 10" Padding="12,10"
                                        IsVisible="{Binding PuedeGestionarCaja}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleFormCierreCommand}"
                                            IsEnabled="{Binding TieneTurnoAbierto}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="[Caja]" FontSize="20" HorizontalOptions="Center"
                                               TextColor="{StaticResource Orange}" />
                                        <Label Text="Gestionar caja" FontSize="11"
                                               TextColor="{StaticResource Orange}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>

                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>
