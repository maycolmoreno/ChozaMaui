<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.PerfilPage"
             x:DataType="vm:PerfilViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="True"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="Auto,*">

        <controls:PosHeaderView Grid.Row="0"
                                InicialesUsuario="{Binding InicialUsuario}"
                                NombreUsuario="{Binding NombreCompleto}"
                                RolUsuario="{Binding RolHeader}"
                                Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                                Kpi1Valor="{Binding HeaderKpi1Valor}"
                                Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                                Kpi2Valor="{Binding HeaderKpi2Valor}"
                                Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                                Kpi3Valor="{Binding HeaderKpi3Valor}"
                                TotalAlertas="{Binding TotalAlertasHeader}"
                                NotificacionesCommand="{Binding IrNotificacionesCommand}"
                                RefreshCommand="{Binding CargarPerfilCommand}" />

        <!-- ── SCROLL DE CONTENIDO ── -->
        <ScrollView Grid.Row="1"
                    VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="16,20,16,40" Spacing="16">

                <!-- CARD AVATAR + INFO -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 22"
                        Padding="20">
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">

                        <!-- Avatar circular con iniciales -->
                        <Border BackgroundColor="{StaticResource PrimaryLight}"
                                Stroke="{StaticResource Primary}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 48"
                                WidthRequest="96" HeightRequest="96"
                                HorizontalOptions="Center">
                            <Label Text="{Binding InicialUsuario}"
                                   FontSize="36" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Nombre -->
                        <Label Text="{Binding NombreCompleto}"
                               Style="{StaticResource TitleMd}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <!-- Username -->
                        <Label Text="{Binding Username, StringFormat='@{0}'}"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center" />

                        <!-- Badge rol -->
                        <Border BackgroundColor="{StaticResource TextPrimary}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 14"
                                Padding="14,6"
                                HorizontalOptions="Center">
                            <Label Text="{Binding Rol}"
                                   TextColor="White"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </Border>

                        <BoxView Style="{StaticResource Divider}" />

                        <!-- Fila de info rápida (ID + turno) -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="{Binding Username}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center" />
                                <Label Text="Usuario"
                                       FontSize="11"
                                       TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1"
                                     WidthRequest="1" HeightRequest="36"
                                     Color="{StaticResource Border}"
                                     HorizontalOptions="Start"
                                     VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- CARD CAMBIAR CONTRASEÑA -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 20"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <!-- Título sección -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border BackgroundColor="{StaticResource PrimaryLight}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    HeightRequest="36" WidthRequest="36">
                                <Label Text="🔒"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1"
                                   Text="Cambiar contraseña"
                                   Style="{StaticResource TitleSm}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Input contraseña actual -->
                        <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0" HeightRequest="50">
                            <Entry Placeholder="Contraseña actual"
                                   IsPassword="True"
                                   Text="{Binding PasswordActual}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   BackgroundColor="Transparent"
                                   FontSize="14" />
                        </Border>

                        <!-- Input nueva contraseña -->
                        <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0" HeightRequest="50">
                            <Entry Placeholder="Nueva contraseña"
                                   IsPassword="True"
                                   Text="{Binding PasswordNuevo}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   BackgroundColor="Transparent"
                                   FontSize="14" />
                        </Border>

                        <!-- Confirmar -->
                        <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,0" HeightRequest="50">
                            <Entry Placeholder="Confirmar nueva contraseña"
                                   IsPassword="True"
                                   Text="{Binding PasswordConfirmar}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   BackgroundColor="Transparent"
                                   FontSize="14" />
                        </Border>

                        <!-- Mensaje éxito / error -->
                        <Border IsVisible="{Binding MensajePassword, Converter={StaticResource StringToBoolConverter}}"
                                StrokeShape="RoundRectangle 12"
                                Padding="12,8">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding MensajeEsError}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource DangerLight}" />
                                    <Setter Property="Stroke" Value="{StaticResource Danger}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding MensajeEsError}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SuccessLight}" />
                                    <Setter Property="Stroke" Value="{StaticResource Success}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding MensajePassword}"
                                   FontSize="13" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding MensajeEsError}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding MensajeEsError}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Success}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>

                        <!-- Botón guardar -->
                        <Button Text="GUARDAR CONTRASEÑA"
                                Command="{Binding CambiarPasswordCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource BtnPrimary}"
                                HeightRequest="52"
                                FontSize="14" />

                    </VerticalStackLayout>
                </Border>

                <!-- CERRAR SESIÓN -->
                <Button Text="CERRAR SESIÓN"
                        Command="{Binding CerrarSesionCommand}"
                        Style="{StaticResource BtnDanger}"
                        HeightRequest="52"
                        FontSize="15"
                        FontAttributes="Bold" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
