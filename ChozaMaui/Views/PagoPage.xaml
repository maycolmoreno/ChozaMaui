<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.PagoPage"
             x:DataType="vm:PagoViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="Auto,*">
        <controls:PosHeaderView Grid.Row="0"
                                MostrarVolver="True"
                                BackCommand="{Binding VolverCommand}"
                                InicialesUsuario="{Binding InicialesUsuario}"
                                NombreUsuario="{Binding NombreUsuarioHeader}"
                                RolUsuario="{Binding RolUsuarioHeader}"
                                Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                                Kpi1Valor="{Binding HeaderKpi1Valor}"
                                Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                                Kpi2Valor="{Binding HeaderKpi2Valor}"
                                Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                                Kpi3Valor="{Binding HeaderKpi3Valor}"
                                TotalAlertas="{Binding TotalAlertasHeader}"
                                NotificacionesCommand="{Binding IrNotificacionesCommand}"
                                RefreshCommand="{Binding CargarCommand}" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Pedido.Detalle}"
                        SelectionMode="None"
                        Margin="16,14,16,0">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout IsVisible="{Binding PagadoCompleto}"
                                         Spacing="12">
                        <Border BackgroundColor="{StaticResource SuccessLight}"
                                Stroke="{StaticResource Success}"
                                StrokeShape="RoundRectangle 22"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12">
                                <Label Text="✓"
                                       FontSize="26"
                                       TextColor="{StaticResource Success}"
                                       VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">
                                    <Label Text="Mesa cobrada y liberada"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Success}" />
                                    <Label Text="{Binding Mensaje}"
                                           FontSize="13"
                                           TextColor="{StaticResource Success}"
                                           IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Button Text="Volver al mapa"
                                Command="{Binding VolverCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                CornerRadius="18"
                                HeightRequest="54" />
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding PagadoCompleto, Converter={StaticResource InvertBoolConverter}}"
                                         Spacing="14">

                        <Border BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 24"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="14">
                                <Border BackgroundColor="{StaticResource PrimaryLight}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 28"
                                        WidthRequest="56"
                                        HeightRequest="56">
                                    <Label Text="M"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Pedido.Mesa.Numero, StringFormat='Mesa {0}'}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding ClienteNombreTexto}"
                                           FontSize="14"
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Label Text="{Binding HoraAperturaTexto, StringFormat='Abierta: {0}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="2"
                                                     HorizontalOptions="End"
                                                     VerticalOptions="Center">
                                    <Label Text="TOTAL A COBRAR"
                                           FontSize="12"
                                           HorizontalTextAlignment="End"
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Label Text="{Binding TotalCobro, StringFormat='${0:F2}'}"
                                           FontSize="32"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="End"
                                           TextColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 24"
                                Padding="16,16,16,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Resumen del pedido"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Column="1"
                                       Text="{Binding CantidadProductosTexto}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PedidoDetalleResponse">
                    <Border BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeThickness="0"
                            Padding="16,4"
                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PagadoCompleto, Converter={StaticResource InvertBoolConverter}}">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Padding="0,4">
                            <Label Text="{Binding Cantidad, StringFormat='{0}x'}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Producto.Nombre}"
                                   Margin="10,0,0,0"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimary}"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="2"
                                   Text="{Binding Consumo, StringFormat='${0:F2}'}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <VerticalStackLayout Spacing="14" Padding="0,0,0,28">
                    <VerticalStackLayout IsVisible="{Binding PagadoCompleto, Converter={StaticResource InvertBoolConverter}}"
                                         Spacing="14">
                        <Border BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 24"
                                Padding="16">
                            <VerticalStackLayout Spacing="12">
                                <BoxView HeightRequest="1"
                                         Color="{StaticResource Border}" />

                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="8">
                                    <Label Text="Consumo"
                                           FontSize="14"
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Consumo, StringFormat='${0:F2}'}"
                                           FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" />

                                    <Label Grid.Row="1"
                                           Text="Saldo a cobrar"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}" />
                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding TotalCobro, StringFormat='${0:F2}'}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 24"
                            Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Método de pago"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />

                            <Grid ColumnDefinitions="*,*,*,*"
                                  ColumnSpacing="10">
                                <Border Grid.Column="0"
                                        BackgroundColor="{Binding EsMetodoEfectivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFF1E7|#FFFFFF'}"
                                        Stroke="{Binding EsMetodoEfectivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EA580C|#DDE3EA'}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoCommand}"
                                                              CommandParameter="EFECTIVO" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="6"
                                                         HorizontalOptions="Center">
                                        <Label Text="$"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Efectivo"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="{Binding EsMetodoTarjeta, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#DBEAFE|#FFFFFF'}"
                                        Stroke="{Binding EsMetodoTarjeta, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#DDE3EA'}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoCommand}"
                                                              CommandParameter="TARJETA" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="6"
                                                         HorizontalOptions="Center">
                                        <Label Text="T"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Info}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Tarjeta"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="2"
                                        BackgroundColor="{Binding EsMetodoTransferencia, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EDE9FE|#FFFFFF'}"
                                        Stroke="{Binding EsMetodoTransferencia, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7C3AED|#DDE3EA'}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoCommand}"
                                                              CommandParameter="TRANSFERENCIA" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="6"
                                                         HorizontalOptions="Center">
                                        <Label Text="TR"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Accent}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Transferencia"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="3"
                                        BackgroundColor="{Binding EsMetodoOtro, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EEF2F6|#FFFFFF'}"
                                        Stroke="{Binding EsMetodoOtro, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#64748B|#DDE3EA'}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="10,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SeleccionarMetodoCommand}"
                                                              CommandParameter="OTRO" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="6"
                                                         HorizontalOptions="Center">
                                        <Label Text="•••"
                                               FontSize="24"
                                               HorizontalOptions="Center" />
                                        <Label Text="Otro"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding EsMetodoEfectivo}"
                            BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 24"
                            Padding="16">
                        <VerticalStackLayout Spacing="14">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="$"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center" />
                                <Label Text="Efectivo"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource TextPrimary}" />
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="3*,2*"
                                  ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource SurfaceSunken}"
                                        Stroke="{StaticResource Border}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="14,10">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Monto recibido"
                                               FontSize="13"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Entry Text="{Binding MontoRecibido}"
                                               Keyboard="Numeric"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               BackgroundColor="Transparent" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="{StaticResource SurfaceSunken}"
                                        Stroke="{StaticResource Border}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="14,10">
                                    <VerticalStackLayout Spacing="4"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center">
                                        <Label Text="Cambio"
                                               FontSize="13"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding Cambio, StringFormat='${0:F2}'}"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource Success}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Border BackgroundColor="{StaticResource PrimaryLight}"
                                    Stroke="{StaticResource PrimarySoft}"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12,10">
                                <Label Text="{Binding NotaMinimoEfectivo}"
                                       FontSize="13"
                                       TextColor="{StaticResource PrimaryDark}" />
                            </Border>

                            <Border IsVisible="{Binding TieneFaltanteEfectivo}"
                                    BackgroundColor="{StaticResource DangerLight}"
                                    Stroke="{StaticResource DangerLight}"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12,10">
                                <Label Text="{Binding FaltaPorRecibir, StringFormat='Falta por recibir ${0:F2}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource Danger}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding EsMetodoTransferencia}"
                            BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 24"
                            Padding="16">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="2">
                                    <Label Text="Comprobante de transferencia"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Sube una foto del comprobante para guardarlo en Dropbox"
                                           FontSize="13"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="Tomar foto"
                                        Command="{Binding CapturarComprobanteCommand}"
                                        BackgroundColor="{StaticResource SurfaceCard}"
                                        BorderColor="{StaticResource Accent}"
                                        BorderWidth="1"
                                        TextColor="{StaticResource Accent}"
                                        CornerRadius="16"
                                        HeightRequest="44" />
                            </Grid>

                            <Border IsVisible="{Binding TieneComprobante}"
                                    HeightRequest="180"
                                    Stroke="{StaticResource Border}"
                                    StrokeShape="RoundRectangle 18">
                                <Image Source="{Binding ImagenComprobante}"
                                       Aspect="AspectFill" />
                            </Border>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Galería"
                                        Command="{Binding SeleccionarFotoGaleriaCommand}"
                                        BackgroundColor="{StaticResource Surface}"
                                        TextColor="{StaticResource TextSecondary}"
                                        BorderColor="{StaticResource Border}"
                                        BorderWidth="1"
                                        CornerRadius="16"
                                        HeightRequest="46" />
                                <Button Grid.Column="1"
                                        Text="{Binding HayErrorComprobante, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Reintentar subida|Subir ahora'}"
                                        Command="{Binding SubirComprobanteCommand}"
                                           IsEnabled="{Binding PuedeAccionarSubidaComprobante}"
                                        BackgroundColor="{StaticResource Accent}"
                                        TextColor="White"
                                        CornerRadius="16"
                                        HeightRequest="46" />
                            </Grid>

                            <ActivityIndicator IsRunning="{Binding SubiendoComprobante}"
                                               IsVisible="{Binding SubiendoComprobante}"
                                               Color="{StaticResource Accent}"
                                               HorizontalOptions="Center" />

                            <Label Text="{Binding ErrorComprobante}"
                                   IsVisible="{Binding HayErrorComprobante}"
                                   FontSize="13"
                                   TextColor="{StaticResource Danger}" />

                            <Border IsVisible="{Binding ComprobanteSubido}"
                                    BackgroundColor="{StaticResource SuccessLight}"
                                    Stroke="{StaticResource SuccessLight}"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12,10">
                                <Label Text="Comprobante listo para guardarse con el cobro"
                                       FontSize="13"
                                       TextColor="{StaticResource Success}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding EsMetodoTarjeta}"
                            BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 24"
                            Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Referencia de tarjeta"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                    Stroke="{StaticResource Border}"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="12,0">
                                <Entry Placeholder="Últimos 4 dígitos o referencia"
                                       Text="{Binding Referencia}"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource TextPrimary}"
                                       PlaceholderColor="{StaticResource TextMuted}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding EsMetodoOtro}"
                            BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 24"
                            Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Detalle del método"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                    Stroke="{StaticResource Border}"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="12,0">
                                <Entry Placeholder="Describe el método o referencia"
                                       Text="{Binding Referencia}"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource TextPrimary}"
                                       PlaceholderColor="{StaticResource TextMuted}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />

                    <Label Text="{Binding Mensaje}"
                           IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}"
                           FontSize="13"
                           TextColor="{StaticResource Primary}"
                           HorizontalTextAlignment="Center" />

                    <Button Command="{Binding CobrarYCerrarMesaCommand}"
                            Text="{Binding TextoBotonCobro}"
                            BackgroundColor="{StaticResource Success}"
                            TextColor="White"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="17"
                            HeightRequest="56"
                            IsEnabled="{Binding PuedeCobrar}" />

                    <Label Text="La mesa se liberará automáticamente al completar el cobro"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                                   </VerticalStackLayout>
                            </VerticalStackLayout>
                     </CollectionView.Footer>
              </CollectionView>
    </Grid>
</ContentPage>
