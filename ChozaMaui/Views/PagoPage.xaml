<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             x:Class="ChozaMaui.Views.PagoPage"
             x:DataType="vm:PagoViewModel"
             Title="Pago / Facturación"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header naranja -->
            <Grid BackgroundColor="{StaticResource Orange}" Padding="16,48,16,20">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Pago / Facturación"
                           FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding Pedido.Idpedido, StringFormat='Pedido #{0}'}"
                           FontSize="14" TextColor="#ffe0b2" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Resumen del pedido -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Resumen del Pedido"
                               FontAttributes="Bold" FontSize="16"
                               TextColor="{StaticResource TextPrimary}" />

                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" RowSpacing="2">
                            <Label Grid.Row="0" Grid.Column="0" Text="Total"
                                   FontSize="11" TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding TotalPedido, StringFormat='${0:F2}'}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center" />

                            <Label Grid.Row="0" Grid.Column="1" Text="Pagado"
                                   FontSize="11" TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding TotalPagado, StringFormat='${0:F2}'}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"
                                   HorizontalTextAlignment="Center" />

                            <Label Grid.Row="0" Grid.Column="2" Text="Saldo"
                                   FontSize="11" TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="2"
                                   Text="{Binding Saldo, StringFormat='${0:F2}'}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center" />
                        </Grid>

                        <!-- Detalles del pedido -->
                        <BoxView HeightRequest="1" Color="#e5e7eb" />
                        <CollectionView ItemsSource="{Binding Pedido.Detalle}"
                                        HeightRequest="140">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:Object">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Grid.Column="0"
                                               Text="{Binding .}"
                                               FontSize="13"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Banner pago completado -->
                <Frame IsVisible="{Binding PagadoCompleto}"
                       BackgroundColor="#f0fdf4" BorderColor="{StaticResource Success}"
                       CornerRadius="10" Padding="14" HasShadow="False">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" FontSize="22" TextColor="{StaticResource Success}"
                               VerticalOptions="Center" />
                        <Label Text="Pago completado. Cuenta cerrada."
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{StaticResource Success}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- Formulario de pago (ocultar si ya completado) -->
                <Frame IsVisible="{Binding PagadoCompleto, Converter={StaticResource InvertBoolConverter}}"
                       BackgroundColor="White" CornerRadius="10" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Registrar Pago"
                               FontAttributes="Bold" FontSize="16"
                               TextColor="{StaticResource TextPrimary}" />

                        <!-- Monto -->
                        <Label Text="Monto a pagar"
                               FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Border BackgroundColor="{StaticResource Gray100}"
                                StrokeShape="RoundRectangle 8" Stroke="#e5e7eb" Padding="12,8">
                            <Entry Placeholder="0.00"
                                   Text="{Binding MontoStr}"
                                   Keyboard="Numeric"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="#9ca3af"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <!-- Método de pago -->
                        <Label Text="Método de pago"
                               FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Picker ItemsSource="{Binding MetodosPago}"
                                SelectedItem="{Binding MetodoSeleccionado}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="White" />

                        <!-- Referencia (tarjeta/transferencia) -->
                        <Label Text="Referencia (opcional)"
                               FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Border BackgroundColor="{StaticResource Gray100}"
                                StrokeShape="RoundRectangle 8" Stroke="#e5e7eb" Padding="12,8">
                            <Entry Placeholder="Nro. comprobante, últimos 4 dígitos..."
                                   Text="{Binding Referencia}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="#9ca3af"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <!-- Botón pagar -->
                        <Button Text="Registrar Pago"
                                Command="{Binding PagarCommand}"
                                BackgroundColor="{StaticResource Orange}"
                                TextColor="White" CornerRadius="8"
                                FontAttributes="Bold" HeightRequest="48"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Confirmación último pago -->
                <Frame IsVisible="{Binding PagoRegistrado}"
                       BackgroundColor="{StaticResource OrangeLight}"
                       BorderColor="{StaticResource Orange}"
                       CornerRadius="10" Padding="14" HasShadow="False">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Último pago registrado"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{StaticResource Orange}" />
                        <Label Text="{Binding UltimoPago.Monto, StringFormat='Monto: ${0:F2}'}"
                               FontSize="13" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding UltimoPago.Metodo, StringFormat='Método: {0}'}"
                               FontSize="13" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding UltimoPago.Fecha, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                               FontSize="12" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Actividad -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Orange}"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding Mensaje}"
                       IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}"
                       FontSize="13" TextColor="{StaticResource Orange}"
                       HorizontalTextAlignment="Center" />

                <!-- Volver -->
                <Button Text="← Volver al Pedido"
                        Command="{Binding VolverCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Orange}"
                        FontSize="14"
                        HorizontalOptions="Center" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
