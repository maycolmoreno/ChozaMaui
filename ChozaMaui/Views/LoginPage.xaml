<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             x:Class="ChozaMaui.Views.LoginPage"
             Title="La Choza — Acceso"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView VerticalScrollBarVisibility="Never">
        <Grid Padding="28,28,28,24"
              MinimumHeightRequest="720">
            <VerticalStackLayout Spacing="14"
                                 VerticalOptions="Center">

				<Image Source="logo.svg"
                   WidthRequest="128"
                   HeightRequest="128"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   Margin="0,4,0,6"/>

			<!-- Subtítulo -->
			<Label Text="Sistema POS"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource TextSecondary}" />

			<BoxView HeightRequest="24" Color="Transparent" />

            <!-- Usuario -->
            <Label Text="Usuario" TextColor="{StaticResource TextPrimary}" FontSize="14" />
            <Entry Placeholder="Ingresa tu usuario"
                   PlaceholderColor="#aaa"
                   TextColor="{StaticResource TextPrimary}"
                   BackgroundColor="White"
                   Text="{Binding Username}"
                   ReturnType="Next"
                   Keyboard="Default" />

            <!-- Contraseña -->
            <Label Text="Contraseña" TextColor="{StaticResource TextPrimary}" FontSize="14" />
            <Grid ColumnDefinitions="*,48"
                  BackgroundColor="White">
                <Entry Grid.Column="0"
                       Placeholder="Ingresa tu contraseña"
                       PlaceholderColor="#aaa"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       Text="{Binding Password}"
                       IsPassword="{Binding PasswordOculta}"
                       ReturnType="Go"
                       ReturnCommand="{Binding LoginCommand}" />
                <ImageButton Grid.Column="1"
                             Source="eye.svg"
                             BackgroundColor="Transparent"
                             Padding="12"
                             Command="{Binding TogglePasswordVisibleCommand}"
                             IsVisible="{Binding PasswordOculta}"
                             SemanticProperties.Description="Mostrar contraseña" />
                <ImageButton Grid.Column="1"
                             Source="eye_off.svg"
                             BackgroundColor="Transparent"
                             Padding="12"
                             Command="{Binding TogglePasswordVisibleCommand}"
                             IsVisible="{Binding PasswordVisible}"
                             SemanticProperties.Description="Ocultar contraseña" />
            </Grid>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                   HorizontalOptions="Center" />

            <!-- Botón -->
            <Button Text="Iniciar sesión"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"
                    FontAttributes="Bold"
                    Margin="0,8,0,0" />

            <!-- Spinner -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" />

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- Panel de configuración del servidor                           -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,16,0,0" />

            <!-- Botón desplegable -->
            <Button Text="⚙ Configurar servidor"
                    Command="{Binding TogglePanelServidorCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource TextMuted}"
                    FontSize="13"
                    HorizontalOptions="Center"
                    Padding="8,4" />

            <!-- Panel colapsable -->
            <Grid IsVisible="{Binding PanelServidorVisible}"
                  BackgroundColor="White"
                  Padding="14">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Dirección del servidor"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />

                    <!-- IP y Puerto en fila -->
                    <Grid ColumnDefinitions="*,Auto,80" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="192.168.1.x"
                               Text="{Binding ServidorHost}"
                               Keyboard="Url"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource TextMuted}"
                               BackgroundColor="{StaticResource SurfaceSunken}"
                               FontSize="14" />
                        <Label Grid.Column="1" Text=":"
                               FontSize="20" TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Entry Grid.Column="2"
                               Placeholder="8081"
                               Text="{Binding ServidorPuerto}"
                               Keyboard="Numeric"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource TextMuted}"
                               BackgroundColor="{StaticResource SurfaceSunken}"
                               FontSize="14" />
                    </Grid>

                    <!-- Preview URL -->
                    <Label Text="{Binding UrlPreview}"
                           FontSize="11" TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center" />

                    <!-- Botones Guardar / Probar -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="💾 Guardar"
                                Command="{Binding GuardarServidorCommand}"
                                BackgroundColor="{StaticResource TextSecondary}"
                                TextColor="White"
                                CornerRadius="8"
                                FontSize="13"
                                HeightRequest="40" />
                        <Button Grid.Column="1"
                                Text="🔗 Probar conexión"
                                Command="{Binding ProbarConexionCommand}"
                                IsEnabled="{Binding ProbandoConexion, Converter={StaticResource InvertBoolConverter}}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="8"
                                FontSize="13"
                                HeightRequest="40" />
                    </Grid>

                    <!-- Estado -->
                    <ActivityIndicator IsRunning="{Binding ProbandoConexion}"
                                       IsVisible="{Binding ProbandoConexion}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                    <Label Text="{Binding EstadoServidor}"
                           IsVisible="{Binding EstadoServidor, Converter={StaticResource StringToBoolConverter}}"
                           TextColor="{Binding EstadoServidorColor}"
                           FontSize="13" FontAttributes="Bold"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
