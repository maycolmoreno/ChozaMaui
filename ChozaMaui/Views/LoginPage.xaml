<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             x:Class="ChozaMaui.Views.LoginPage"
             Title="La Choza — Acceso"
             BackgroundColor="{StaticResource Gray100}">

    

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="16" VerticalOptions="Center">

			<!-- Logo -->
			<Image Source="lachozalogo.png"
                   HeightRequest="150"
                   HorizontalOptions="Center"
                   Margin="0,20,0,10"/>

			<!-- Subtítulo -->
			<Label Text="Sistema POS"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource TextSecondary}" />

			<BoxView HeightRequest="24" Color="Transparent" />

            <!-- Usuario -->
            <Label Text="Usuario" TextColor="{StaticResource TextPrimary}" FontSize="14" />
            <Entry Placeholder="Ingresa tu usuario"
                   PlaceholderColor="#aaa"
                   TextColor="{StaticResource TextPrimary}"
                   BackgroundColor="White"
                   Text="{Binding Username}"
                   ReturnType="Next"
                   Keyboard="Default" />

            <!-- Contraseña -->
            <Label Text="Contraseña" TextColor="{StaticResource TextPrimary}" FontSize="14" />
            <Entry Placeholder="Ingresa tu contraseña"
                   PlaceholderColor="#aaa"
                   TextColor="{StaticResource TextPrimary}"
                   BackgroundColor="White"
                   Text="{Binding Password}"
                   IsPassword="True"
                   ReturnType="Go"
                   ReturnCommand="{Binding LoginCommand}" />

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#ff6b6b"
                   FontSize="13"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                   HorizontalOptions="Center" />

            <!-- Botón -->
            <Button Text="Iniciar sesión"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"
                    FontAttributes="Bold"
                    Margin="0,8,0,0" />

            <!-- Spinner -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" />

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- Panel de configuración del servidor                           -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <BoxView HeightRequest="1" Color="#e5e7eb" Margin="0,16,0,0" />

            <!-- Botón desplegable -->
            <Button Text="⚙ Configurar servidor"
                    Command="{Binding TogglePanelServidorCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#9ca3af"
                    FontSize="13"
                    HorizontalOptions="Center"
                    Padding="8,4" />

            <!-- Panel colapsable -->
            <Border IsVisible="{Binding PanelServidorVisible}"
                    BackgroundColor="White"
                    Stroke="#e2e8f0"
                    StrokeShape="RoundRectangle 12"
                    Padding="16">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Dirección del servidor"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#374151" />

                    <!-- IP y Puerto en fila -->
                    <Grid ColumnDefinitions="*,Auto,80" ColumnSpacing="8">
                        <Border Grid.Column="0"
                                BackgroundColor="#f3f4f6"
                                StrokeShape="RoundRectangle 8" Stroke="#e5e7eb" Padding="10,6">
                            <Entry Placeholder="192.168.1.x"
                                   Text="{Binding ServidorHost}"
                                   Keyboard="Url"
                                   TextColor="#111827"
                                   PlaceholderColor="#9ca3af"
                                   BackgroundColor="Transparent"
                                   FontSize="14" />
                        </Border>
                        <Label Grid.Column="1" Text=":"
                               FontSize="20" TextColor="#6b7280"
                               VerticalOptions="Center" />
                        <Border Grid.Column="2"
                                BackgroundColor="#f3f4f6"
                                StrokeShape="RoundRectangle 8" Stroke="#e5e7eb" Padding="10,6">
                            <Entry Placeholder="8081"
                                   Text="{Binding ServidorPuerto}"
                                   Keyboard="Numeric"
                                   TextColor="#111827"
                                   PlaceholderColor="#9ca3af"
                                   BackgroundColor="Transparent"
                                   FontSize="14" />
                        </Border>
                    </Grid>

                    <!-- Preview URL -->
                    <Label Text="{Binding UrlPreview}"
                           FontSize="11" TextColor="#9ca3af"
                           HorizontalOptions="Center" />

                    <!-- Botones Guardar / Probar -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="💾 Guardar"
                                Command="{Binding GuardarServidorCommand}"
                                BackgroundColor="#6b7280"
                                TextColor="White"
                                CornerRadius="8"
                                FontSize="13"
                                HeightRequest="40" />
                        <Button Grid.Column="1"
                                Text="🔗 Probar conexión"
                                Command="{Binding ProbarConexionCommand}"
                                IsEnabled="{Binding ProbandoConexion, Converter={StaticResource InvertBoolConverter}}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="8"
                                FontSize="13"
                                HeightRequest="40" />
                    </Grid>

                    <!-- Estado -->
                    <ActivityIndicator IsRunning="{Binding ProbandoConexion}"
                                       IsVisible="{Binding ProbandoConexion}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                    <Label Text="{Binding EstadoServidor}"
                           IsVisible="{Binding EstadoServidor, Converter={StaticResource StringToBoolConverter}}"
                           TextColor="{Binding EstadoServidorColor}"
                           FontSize="13" FontAttributes="Bold"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
