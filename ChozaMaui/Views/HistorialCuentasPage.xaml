<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.HistorialCuentasPage"
             x:DataType="vm:HistorialCuentasViewModel"
             Title="Cobros"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="Auto,*">
		<controls:PosHeaderView Grid.Row="0"
                        InicialesUsuario="{Binding InicialUsuario}"
                        NombreUsuario="{Binding NombreUsuario}"
                        RolUsuario="{Binding RolUsuario}"
                        Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                        Kpi1Valor="{Binding HeaderKpi1Valor}"
                        Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                        Kpi2Valor="{Binding HeaderKpi2Valor}"
                        Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                        Kpi3Valor="{Binding HeaderKpi3Valor}"
                        TotalAlertas="{Binding TotalAlertasHeader}"
                        NotificacionesCommand="{Binding IrNotificacionesCommand}"
                        RefreshCommand="{Binding CargarCommand}" />

		<CollectionView Grid.Row="1"
                        ItemsSource="{Binding Cuentas}"
                        SelectionMode="None">
            <CollectionView.Header>
                <VerticalStackLayout Padding="16,14,16,10"
                                     Spacing="14">
                    <Border BackgroundColor="White"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 22"
                            Padding="10,2">
                        <SearchBar Placeholder="Buscar por mesa, cuenta o cliente..."
                                   Text="{Binding TextoBusqueda}"
                                   FontSize="14"
                                   BackgroundColor="Transparent"
                                   CancelButtonColor="{StaticResource Primary}" />
                    </Border>

                    <Border BackgroundColor="{StaticResource SurfaceCard}"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 20"
                            Padding="4">
                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="6">
                            <Button Grid.Column="0"
                                    Command="{Binding MostrarPendientesCommand}"
                                    Text="{Binding TotalPendientes, StringFormat='Pendientes {0}'}"
                                    BackgroundColor="{Binding TabPendientesActivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EA580C|#FFFFFF'}"
                                    TextColor="{Binding TabPendientesActivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#4B5563'}"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    HeightRequest="44" />

                            <Button Grid.Column="1"
                                    Command="{Binding MostrarCobradasCommand}"
                                    Text="{Binding TotalCobradas, StringFormat='Cobradas {0}'}"
                                    BackgroundColor="{Binding TabCobradasActivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EA580C|#FFFFFF'}"
                                    TextColor="{Binding TabCobradasActivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#4B5563'}"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    HeightRequest="44" />

                            <Button Grid.Column="2"
                                    Command="{Binding MostrarTodasCommand}"
                                    Text="Todas"
                                    BackgroundColor="{Binding TabTodasActivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EA580C|#FFFFFF'}"
                                    TextColor="{Binding TabTodasActivo, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#4B5563'}"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    HeightRequest="44" />
                        </Grid>
                    </Border>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />

                    <Label Text="{Binding Mensaje}"
                           IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}"
                           FontSize="13"
                           TextColor="{StaticResource Primary}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.Header>

           
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CuentaResponse">
                    <Border Margin="16,0,16,12"
                            Padding="14"
                            BackgroundColor="{StaticResource SurfaceCard}"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 22">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource PrimaryLight}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 26"
                                    WidthRequest="52"
                                    HeightRequest="52">
                                <Label Text="🍽"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding MesaTexto}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding ClienteTexto}"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding FechaApertura, StringFormat='Abierta: {0:hh:mm tt}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding Idcuenta, StringFormat='Cuenta #{0}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2"
                                                 Spacing="10"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding Total, StringFormat='${0:F2}'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="End"
                                       TextColor="{StaticResource Primary}" />

                                <Button Text="COBRAR"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CobrarCuentaCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        CornerRadius="14"
                                        FontAttributes="Bold"
                                        HeightRequest="42"
                                        WidthRequest="120">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Estado}"
                                                     Value="ABIERTA">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Estado}"
                                                     Value="PAGADA">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Estado}"
                                                     Value="CERRADA">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Estado}"
                                                     Value="ANULADA">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>

                                <Border Padding="10,6"
                                        BackgroundColor="{StaticResource SurfaceSunken}"
                                        Stroke="{StaticResource Border}"
                                        StrokeShape="RoundRectangle 12"
                                        IsVisible="False">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Estado}"
                                                     Value="PAGADA">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Estado}"
                                                     Value="CERRADA">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Estado}"
                                                     Value="ANULADA">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Estado}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextSecondary}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
