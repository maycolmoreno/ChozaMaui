<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             x:Class="ChozaMaui.Views.AdminPage"
             x:DataType="vm:AdminViewModel"
             Title="Admin"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header naranja -->
            <Grid BackgroundColor="{StaticResource Orange}" Padding="16,48,16,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="lachozalogo.png"
                       HeightRequest="44" WidthRequest="44"
                       Aspect="AspectFit"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Panel Administrativo"
                           FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding FechaReporte, StringFormat='Reporte del {0:dd/MM/yyyy}'}"
                           FontSize="13" TextColor="#ffe0b2" />
                </VerticalStackLayout>
                <Button Grid.Column="2" Text="↻" FontSize="20" TextColor="White"
                        BackgroundColor="Transparent"
                        Command="{Binding CargarCommand}"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Indicador -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Orange}"
                               HorizontalOptions="Center" Margin="0,20" />

            <VerticalStackLayout Padding="16" Spacing="14"
                                 IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}">

                <!-- ── Ventas del día ── -->
                <Label Text="Ventas del Día" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                    <!-- Total Ventas -->
                    <Frame Grid.Row="0" Grid.Column="0"
                           BackgroundColor="White" CornerRadius="10" Padding="14" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="💰 Total Ventas" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding TotalVentas, StringFormat='${0:F2}'}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Orange}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Número Pedidos -->
                    <Frame Grid.Row="0" Grid.Column="1"
                           BackgroundColor="White" CornerRadius="10" Padding="14" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🧾 Pedidos" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding NumeroPedidos}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Ticket Promedio -->
                    <Frame Grid.Row="1" Grid.Column="0"
                           BackgroundColor="White" CornerRadius="10" Padding="14" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="📊 Ticket Promedio" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding TicketPromedio, StringFormat='${0:F2}'}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Total Productos -->
                    <Frame Grid.Row="1" Grid.Column="1"
                           BackgroundColor="White" CornerRadius="10" Padding="14" HasShadow="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="📦 Productos" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding TotalProductos}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- ── Turno activo ── -->
                <Label Text="Turno Activo" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" Margin="0,6,0,0" />

                <!-- Sin turno -->
                <Frame IsVisible="{Binding TieneTurnoAbierto, Converter={StaticResource InvertBoolConverter}}"
                       BackgroundColor="White" CornerRadius="10" Padding="14" HasShadow="False">
                    <Label Text="No hay turno abierto." FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                </Frame>

                <!-- Con turno -->
                <Frame IsVisible="{Binding TieneTurnoAbierto}"
                       BackgroundColor="{StaticResource OrangeLight}"
                       BorderColor="{StaticResource Orange}"
                       CornerRadius="10" Padding="14" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🔓" FontSize="24"
                               VerticalOptions="Center" Margin="0,0,12,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Turno en curso" FontAttributes="Bold"
                                   TextColor="{StaticResource Orange}" FontSize="14" />
                            <Label Text="{Binding TurnoActivo.UsuarioApertura, StringFormat='Cajero: {0}'}"
                                   FontSize="13" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding TurnoActivo.FechaApertura, StringFormat='Desde: {0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding TurnoActivo.MontoInicial, StringFormat='Monto inicial: ${0:F2}'}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- ── Estado de mesas ── -->
                <Label Text="Estado de Mesas" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" Margin="0,6,0,0" />

                <Frame BackgroundColor="White" CornerRadius="10" Padding="14" HasShadow="False">
                    <Grid ColumnDefinitions="*,*,*">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Total" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding TotalMesas}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Disponibles" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding MesasDisponibles}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                            <Label Text="Ocupadas" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding MesasOcupadas}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- ── Productos más vendidos ── -->
                <Label Text="Productos Más Vendidos" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" Margin="0,6,0,0" />

                <Frame BackgroundColor="White" CornerRadius="10" Padding="0" HasShadow="False">
                    <CollectionView ItemsSource="{Binding ProductosTop}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ResumenProductoVenta">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,10">
                                    <!-- Ranking badge -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource Orange}"
                                            StrokeShape="RoundRectangle 14"
                                            Stroke="Transparent"
                                            WidthRequest="28" HeightRequest="28"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            Margin="0,0,12,0">
                                        <Label Text="#" FontSize="11" TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding NombreProducto}"
                                               FontAttributes="Bold" FontSize="14"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding TotalVendido, StringFormat='Total: ${0:F2}'}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding CantidadVendida, StringFormat='{0} uds'}"
                                           FontAttributes="Bold" FontSize="14"
                                           TextColor="{StaticResource Orange}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

                <!-- Mensaje error -->
                <Label Text="{Binding Mensaje}"
                       IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}"
                       FontSize="13" TextColor="{StaticResource Primary}"
                       HorizontalTextAlignment="Center" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
