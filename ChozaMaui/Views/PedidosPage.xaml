<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             x:Class="ChozaMaui.Views.PedidosPage"
             x:DataType="vm:PedidosViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f5f7fb">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="16,52,16,16">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                <Border Grid.Column="0" BackgroundColor="#f0f4f8"
                        StrokeShape="RoundRectangle 22" Stroke="Transparent"
                        WidthRequest="44" HeightRequest="44">
                    <Label Text="👤" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Image Grid.Column="1" Source="lachozalogo.png"
                       HeightRequest="40"
                       HorizontalOptions="Center"
                       Aspect="AspectFit"
                       VerticalOptions="Center" />
                <ActivityIndicator Grid.Column="2"
                                   IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Orange}" VerticalOptions="Center"/>
                <Border Grid.Column="3" BackgroundColor="#f0f4f8"
                        StrokeShape="RoundRectangle 22" Stroke="Transparent"
                        WidthRequest="44" HeightRequest="44">
                    <Label Text="🔔" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ KPI CARDS ══ -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
              Padding="12,10,12,4" RowSpacing="8" ColumnSpacing="8">

            <!-- Kitchen Load -->
            <Border Grid.Column="0" Grid.Row="0"
                    BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="14,12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="KITCHEN LOAD" TextColor="{StaticResource TextSecondary}"
                           FontSize="10" FontAttributes="Bold" />
                    <Label Text="{Binding CargaCocinaLabel}"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{Binding CargaCocinaColor, Converter={StaticResource HexToColorConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Active Orders -->
            <Border Grid.Column="1" Grid.Row="0"
                    BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="14,12">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                        <Label Text="ACTIVE ORDERS" TextColor="{StaticResource TextSecondary}"
                               FontSize="10" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding PedidosActivos}"
                           FontSize="38" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Avg Time -->
            <Border Grid.Column="0" Grid.Row="1"
                    BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="14,12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Grid.Column="0" Text="⏱" FontSize="24"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="AVG TIME" TextColor="{StaticResource TextSecondary}"
                               FontSize="10" FontAttributes="Bold" />
                        <Label Text="{Binding TiempoPromedioTexto}"
                               FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Completed -->
            <Border Grid.Column="1" Grid.Row="1"
                    BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="14,12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Grid.Column="0" Text="✅" FontSize="24"
                           VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="COMPLETED" TextColor="{StaticResource TextSecondary}"
                               FontSize="10" FontAttributes="Bold" />
                        <Label Text="{Binding TotalCompletados}"
                               FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ BUSCAR + FILTRO ══ -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              Padding="12,4,12,8" ColumnSpacing="8">
            <Border Grid.Column="0"
                    BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="4,0">
                <SearchBar Placeholder="Buscar mesa o mesero…"
                           PlaceholderColor="#9ca3af" TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="Transparent"
                           Text="{Binding Busqueda}" />
            </Border>
            <Border Grid.Column="1"
                    BackgroundColor="White" StrokeShape="RoundRectangle 12"
                    Stroke="#e2e8f0" Padding="4,0" WidthRequest="130">
                <Picker ItemsSource="{Binding Estados}"
                        SelectedItem="{Binding FiltroEstado}"
                        TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent" />
            </Border>
        </Grid>

        <!-- ══ LISTA DE PEDIDOS ══ -->
        <RefreshView Grid.Row="3"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding CargarCommand}">
            <CollectionView ItemsSource="{Binding Pedidos}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="12" Margin="0,60">
                        <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Sin pedidos con ese filtro"
                               TextColor="#6b7280" FontSize="15"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PedidoResponse">
                        <Grid Margin="12,5">
                            <Border BackgroundColor="White"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="#e2e8f0"
                                    StrokeThickness="1"
                                    Padding="0">
                                <!-- Grid: columna izquierda = franja de color, derecha = contenido -->
                                <Grid ColumnDefinitions="6,*">
                                    <!-- Franja lateral de color por estado -->
                                    <BoxView Grid.Column="0"
                                             Color="{Binding EstadoBorderColor, Converter={StaticResource HexToColorConverter}}"
                                             CornerRadius="12,0,0,12" />

                                    <!-- Contenido de la tarjeta -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="14,12,14,12"
                                                         Spacing="8">

                                        <!-- Fila 1: Badge estado + # pedido + Tiempo -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="{Binding EstadoBadgeBackground, Converter={StaticResource HexToColorConverter}}"
                                                    StrokeShape="RoundRectangle 6"
                                                    Stroke="Transparent"
                                                    Padding="8,3">
                                                <Label Text="{Binding Estado}"
                                                       TextColor="White"
                                                       FontSize="10" FontAttributes="Bold" />
                                            </Border>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Idpedido, StringFormat='  #{0}'}"
                                                   TextColor="{StaticResource TextSecondary}" FontSize="12"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="2"
                                                   Text="{Binding TiempoTranscurrido}"
                                                   TextColor="{StaticResource TextPrimary}" FontSize="17"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <!-- Fila 2: Mesa + Mesero -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Mesa.Etiqueta}"
                                                   TextColor="{StaticResource TextPrimary}" FontSize="19"
                                                   FontAttributes="Bold" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Usuario.NombreCompleto, StringFormat='Mesero: {0}'}"
                                                   TextColor="{StaticResource TextSecondary}" FontSize="12"
                                                   VerticalOptions="End" />
                                        </Grid>

                                        <!-- Fila 3: Barra de progreso -->
                                        <ProgressBar Progress="{Binding BarraProgreso}"
                                                     ProgressColor="{Binding BarraProgresoColor, Converter={StaticResource HexToColorConverter}}"
                                                     BackgroundColor="#e2e8f0"
                                                     HeightRequest="6" />

                                        <!-- Fila 4: Etiquetas del progreso -->
                                        <Grid ColumnDefinitions="*,*,*">
                                            <Label Grid.Column="0"
                                                   Text="RECIBIDO"
                                                   TextColor="{StaticResource TextSecondary}" FontSize="9" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding EtapaActualLabel}"
                                                   TextColor="{Binding BarraProgresoColor, Converter={StaticResource HexToColorConverter}}"
                                                   FontSize="9" FontAttributes="Bold"
                                                   HorizontalOptions="Center" />
                                            <Label Grid.Column="2"
                                                   Text="LISTO"
                                                   TextColor="{StaticResource TextSecondary}" FontSize="9"
                                                   HorizontalOptions="End" />
                                        </Grid>

                                        <!-- Fila 5: Resumen items + Ver detalle + Cobrar -->
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding ResumenItems}"
                                                   TextColor="#9ca3af" FontSize="12"
                                                   LineBreakMode="TailTruncation"
                                                   VerticalOptions="Center" />
                                            <!-- Botón Cobrar (solo estados LISTO / ENTREGADO) -->
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#28b779"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="Transparent"
                                                    Padding="10,5"
                                                    IsVisible="{Binding EsCobrable}">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IrAPagarCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="💳 Cobrar"
                                                       TextColor="White"
                                                       FontSize="11" FontAttributes="Bold" />
                                            </Border>
                                            <Label Grid.Column="2"
                                                   Text="VER  ›"
                                                   TextColor="{StaticResource Orange}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetalleCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Grid>

                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
