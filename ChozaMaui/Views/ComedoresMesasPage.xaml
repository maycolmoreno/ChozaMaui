<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             x:Class="ChozaMaui.Views.ComedoresMesasPage"
             x:DataType="vm:ComedoresMesasViewModel"
             Title="Comedores y Mesas"
             BackgroundColor="{StaticResource Gray100}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ══ HEADER NARANJA ══ -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Orange}" Padding="16,48,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Comedores y Mesas"
                       FontSize="22" FontAttributes="Bold" TextColor="White" />
                <Label FontSize="13" TextColor="#ffe0b2">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding MostrarMesas}" Value="False">
                            <Setter Property="Text" Value="{Binding Comedores.Count, StringFormat='{0} comedores'}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding MostrarMesas}" Value="True">
                            <Setter Property="Text" Value="{Binding Mesas.Count, StringFormat='{0} mesas'}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>
            <Button Grid.Column="1" FontSize="13" TextColor="White"
                    BackgroundColor="#e67e00" CornerRadius="8" Padding="12,6"
                    VerticalOptions="Center">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding MostrarMesas}" Value="False">
                        <Setter Property="Text" Value="+ Comedor" />
                        <Setter Property="Command" Value="{Binding AbrirNuevoComedorCommand}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding MostrarMesas}" Value="True">
                        <Setter Property="Text" Value="+ Mesa" />
                        <Setter Property="Command" Value="{Binding AbrirNuevaMesaCommand}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- ══ TABS ══ -->
        <Grid Grid.Row="1" BackgroundColor="{StaticResource Orange}" Padding="16,0,16,12"
              ColumnDefinitions="*,*" ColumnSpacing="8">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="0">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding MostrarMesas}" Value="False">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding MostrarMesas}" Value="True">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Button Text="Comedores" CornerRadius="20" Padding="0,8"
                        BackgroundColor="Transparent"
                        Command="{Binding VerComedoresCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding MostrarMesas}" Value="False">
                            <Setter Property="TextColor" Value="{StaticResource Orange}" />
                            <Setter Property="FontAttributes" Value="Bold" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding MostrarMesas}" Value="True">
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="FontAttributes" Value="None" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Border>
            <Border Grid.Column="1" StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="0">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding MostrarMesas}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding MostrarMesas}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Button Text="Mesas" CornerRadius="20" Padding="0,8"
                        BackgroundColor="Transparent"
                        Command="{Binding VerMesasCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding MostrarMesas}" Value="True">
                            <Setter Property="TextColor" Value="{StaticResource Orange}" />
                            <Setter Property="FontAttributes" Value="Bold" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding MostrarMesas}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="FontAttributes" Value="None" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Border>
        </Grid>

        <!-- ══ CONTENIDO ══ -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="0">

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Orange}"
                                   HorizontalOptions="Center" Margin="0,20" />

                <VerticalStackLayout Padding="16" Spacing="12"
                                     IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}">

                    <!-- Mensaje feedback -->
                    <Frame IsVisible="{Binding Mensaje, Converter={StaticResource StringToBoolConverter}}"
                           CornerRadius="8" Padding="12" HasShadow="False">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame" Binding="{Binding MensajeExito}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource OrangeLight}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Frame" Binding="{Binding MensajeExito}" Value="False">
                                <Setter Property="BackgroundColor" Value="#fdecea" />
                            </DataTrigger>
                        </Frame.Triggers>
                        <Label Text="{Binding Mensaje}" FontSize="13"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center" />
                    </Frame>

                    <!-- ══════════════════════════════════════════════
                         SECCIÓN COMEDORES
                    ══════════════════════════════════════════════ -->
                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding MostrarMesas, Converter={StaticResource InvertBoolConverter}}">

                        <!-- Formulario comedor -->
                        <Frame IsVisible="{Binding MostrarFormComedor}"
                               BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="False">
                            <VerticalStackLayout Spacing="10">
                                <Label FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource Orange}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding EsEdicionComedor}" Value="True">
                                            <Setter Property="Text" Value="Editar comedor" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding EsEdicionComedor}" Value="False">
                                            <Setter Property="Text" Value="Nuevo comedor" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Entry Placeholder="Nombre *" Text="{Binding FormCNombre}"
                                       BackgroundColor="{StaticResource Gray100}" FontSize="14" />
                                <Entry Placeholder="Descripción"
                                       Text="{Binding FormCDescripcion}"
                                       BackgroundColor="{StaticResource Gray100}" FontSize="14" />
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Label Text="Activo" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                    <Switch IsToggled="{Binding FormCEstado}"
                                            OnColor="{StaticResource Orange}" />
                                </HorizontalStackLayout>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Text="Cancelar"
                                            BackgroundColor="{StaticResource Gray100}"
                                            TextColor="{StaticResource TextSecondary}"
                                            CornerRadius="8"
                                            Command="{Binding CancelarFormComedorCommand}" />
                                    <Button Grid.Column="1" Text="Guardar"
                                            BackgroundColor="{StaticResource Orange}"
                                            TextColor="White" CornerRadius="8"
                                            Command="{Binding GuardarComedorCommand}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Lista comedores (BindableLayout evita CollectionView anidado en ScrollView) -->
                        <Label Text="No hay comedores registrados."
                               IsVisible="{Binding Comedores, Converter={StaticResource IntIsZeroConverter}}"
                               FontSize="14" TextColor="{StaticResource TextSecondary}"
                               HorizontalTextAlignment="Center" Padding="0,8" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Comedores}"
                                             Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:ComedorResponse">
                                    <Frame BackgroundColor="White" CornerRadius="10"
                                           Padding="14" HasShadow="False" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding Nombre}"
                                                       FontAttributes="Bold" FontSize="15"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label Text="{Binding Descripcion}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       LineBreakMode="TailTruncation"
                                                       IsVisible="{Binding Descripcion, Converter={StaticResource StringToBoolConverter}}" />
                                                <Border BackgroundColor="{Binding EstadoColor, Converter={StaticResource HexToColorConverter}}"
                                                        StrokeShape="RoundRectangle 8"
                                                        Stroke="Transparent" Padding="6,2"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{Binding EstadoTexto}"
                                                           FontSize="11" TextColor="White"
                                                           FontAttributes="Bold" />
                                                </Border>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="1" Text="✏️" FontSize="18"
                                                    BackgroundColor="Transparent"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ComedoresMesasViewModel}}, Path=AbrirEdicionComedorCommand}"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center" />
                                            <Button Grid.Column="2" Text="🗑️" FontSize="18"
                                                    BackgroundColor="Transparent"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ComedoresMesasViewModel}}, Path=EliminarComedorCommand}"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- ══════════════════════════════════════════════
                         SECCIÓN MESAS
                    ══════════════════════════════════════════════ -->
                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding MostrarMesas}">

                        <!-- Formulario mesa -->
                        <Frame IsVisible="{Binding MostrarFormMesa}"
                               BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="False">
                            <VerticalStackLayout Spacing="10">
                                <Label FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource Orange}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding EsEdicionMesa}" Value="True">
                                            <Setter Property="Text" Value="Editar mesa" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding EsEdicionMesa}" Value="False">
                                            <Setter Property="Text" Value="Nueva mesa" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Entry Grid.Column="0" Placeholder="Número *"
                                           Text="{Binding FormMNumero}" Keyboard="Numeric"
                                           BackgroundColor="{StaticResource Gray100}" FontSize="14" />
                                    <Entry Grid.Column="1" Placeholder="Capacidad *"
                                           Text="{Binding FormMCapacidad}" Keyboard="Numeric"
                                           BackgroundColor="{StaticResource Gray100}" FontSize="14" />
                                </Grid>
                                <Picker Title="Comedor (opcional)"
                                        ItemsSource="{Binding Comedores}"
                                        SelectedItem="{Binding FormMComedor}"
                                        ItemDisplayBinding="{Binding Nombre}"
                                        BackgroundColor="{StaticResource Gray100}"
                                        FontSize="14" />
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Label Text="Disponible" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                    <Switch IsToggled="{Binding FormMEstado}"
                                            OnColor="{StaticResource Orange}" />
                                </HorizontalStackLayout>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Text="Cancelar"
                                            BackgroundColor="{StaticResource Gray100}"
                                            TextColor="{StaticResource TextSecondary}"
                                            CornerRadius="8"
                                            Command="{Binding CancelarFormMesaCommand}" />
                                    <Button Grid.Column="1" Text="Guardar"
                                            BackgroundColor="{StaticResource Orange}"
                                            TextColor="White" CornerRadius="8"
                                            Command="{Binding GuardarMesaCommand}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Chips filtro por comedor -->
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Spacing="8" Padding="0,2">
                                <Border StrokeShape="RoundRectangle 14" Stroke="Transparent" Padding="12,6">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ComedorFiltro}" Value="{x:Null}">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Orange}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding VerMesasCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Todas" FontSize="13"
                                           TextColor="White" FontAttributes="Bold" />
                                </Border>
                                <CollectionView ItemsSource="{Binding Comedores}"
                                                ItemsLayout="HorizontalList">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ComedorResponse">
                                            <Border StrokeShape="RoundRectangle 14"
                                                    BackgroundColor="{StaticResource OrangeLight}"
                                                    Stroke="Transparent" Padding="12,6" Margin="0,0,8,0">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ComedoresMesasViewModel}}, Path=VerMesasCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="{Binding Nombre}" FontSize="13"
                                                       TextColor="{StaticResource Orange}" />
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </HorizontalStackLayout>
                        </ScrollView>

                        <!-- Lista mesas (BindableLayout evita CollectionView anidado en ScrollView) -->
                        <Label Text="No hay mesas registradas."
                               IsVisible="{Binding Mesas, Converter={StaticResource IntIsZeroConverter}}"
                               FontSize="14" TextColor="{StaticResource TextSecondary}"
                               HorizontalTextAlignment="Center" Padding="0,8" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Mesas}"
                                             Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:MesaResponse">
                                    <Frame BackgroundColor="{Binding CardBackground, Converter={StaticResource HexToColorConverter}}"
                                           BorderColor="{Binding StrokeColor, Converter={StaticResource HexToColorConverter}}"
                                           CornerRadius="10"
                                           Padding="14" HasShadow="False" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="{Binding EstadoColor, Converter={StaticResource HexToColorConverter}}"
                                                    StrokeShape="RoundRectangle 10"
                                                    Stroke="Transparent"
                                                    WidthRequest="54" HeightRequest="54"
                                                    VerticalOptions="Center">
                                                <VerticalStackLayout VerticalOptions="Center"
                                                                     HorizontalOptions="Center">
                                                    <Label Text="{Binding Numero}"
                                                           FontSize="20" FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalOptions="Center" />
                                                    <Label Text="Mesa" FontSize="9" TextColor="White"
                                                           HorizontalOptions="Center" />
                                                </VerticalStackLayout>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="4"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding NombreComedor}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label Text="{Binding Capacidad, StringFormat='Capacidad: {0} personas'}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}" />
                                                <Border BackgroundColor="{Binding EstadoColor, Converter={StaticResource HexToColorConverter}}"
                                                        StrokeShape="RoundRectangle 6"
                                                        Stroke="Transparent"
                                                        Padding="8,3"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{Binding EstadoTexto}"
                                                           FontSize="11" FontAttributes="Bold"
                                                           TextColor="White" />
                                                </Border>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="2" Text="✏️" FontSize="18"
                                                    BackgroundColor="Transparent"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ComedoresMesasViewModel}}, Path=AbrirEdicionMesaCommand}"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center" />
                                            <Button Grid.Column="3" Text="🗑️" FontSize="18"
                                                    BackgroundColor="Transparent"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ComedoresMesasViewModel}}, Path=EliminarMesaCommand}"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
