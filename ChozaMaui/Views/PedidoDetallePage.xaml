<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:viewModels="clr-namespace:ChozaMaui.ViewModels"
             x:Class="ChozaMaui.Views.PedidoDetallePage"
             x:DataType="viewModels:PedidoDetalleViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f5f7fb">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0"
                BackgroundColor="#f26522"
                StrokeThickness="0"
                Padding="14,20,14,16">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Button Grid.Row="0"
                        Grid.Column="0"
                        Text="‹"
                        FontSize="30"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        Padding="0"
                        WidthRequest="32"
                        HeightRequest="36"
                        Command="{Binding VolverCommand}" />

                <VerticalStackLayout Grid.Row="0"
                                     Grid.Column="1"
                                     Spacing="0">
                    <Label Text="{Binding TituloPedido}"
                           FontSize="36"
                           TextColor="White"
                           FontAttributes="Bold" />
                    <Label Text="{Binding SubtituloPedido}"
                           FontSize="18"
                           TextColor="#ffe8dc" />
                </VerticalStackLayout>

                <Border Grid.Row="0"
                        Grid.Column="2"
                        BackgroundColor="#f59e0b"
                        StrokeThickness="0"
                        Padding="14,6"
                        StrokeShape="RoundRectangle 10"
                        VerticalOptions="Center">
                    <Label Text="{Binding EstadoBadgeTexto}"
                           TextColor="White"
                           FontSize="13"
                           FontAttributes="Bold" />
                </Border>

                <Label Grid.Row="0"
                       Grid.Column="3"
                       Text="⋮"
                       FontSize="28"
                       TextColor="White"
                       VerticalOptions="Center" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="12" Spacing="12">

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#f26522"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#ef4444"
                       FontSize="13"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

                <Border BackgroundColor="White"
                        Stroke="#e5e7eb"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Cliente" TextColor="#6b7280" FontSize="13" />
                            <Label Text="{Binding ClienteTexto}" TextColor="#111827" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding ClienteTelefonoTexto}" TextColor="#6b7280" FontSize="14" />
                        </VerticalStackLayout>

                        <BoxView Grid.Column="0" HorizontalOptions="End" WidthRequest="1" Color="#e5e7eb" />

                        <VerticalStackLayout Grid.Column="1" Spacing="2" Padding="14,0,0,0">
                            <Label Text="Mesa" TextColor="#6b7280" FontSize="13" />
                            <Label Text="{Binding MesaTexto}" TextColor="#111827" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding MesaCapacidadTexto}" TextColor="#6b7280" FontSize="14" />
                        </VerticalStackLayout>

                        <BoxView Grid.Column="1" HorizontalOptions="End" WidthRequest="1" Color="#e5e7eb" />

                        <VerticalStackLayout Grid.Column="2" Spacing="2" Padding="14,0,0,0">
                            <Label Text="Mesero" TextColor="#6b7280" FontSize="13" />
                            <Label Text="{Binding MeseroTexto}" TextColor="#111827" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding MeseroHoraTexto}" TextColor="#6b7280" FontSize="14" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#e5e7eb"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Productos"
                                   FontSize="36"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                            
                        </Grid>

                        <CollectionView ItemsSource="{Binding Detalles}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PedidoDetalleResponse">
                                    <Grid ColumnDefinitions="66,50,*,Auto,24"
                                          ColumnSpacing="10"
                                          Padding="0,8">
                                        <Border Grid.Column="0"
                                                BackgroundColor="#f3f4f6"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                HeightRequest="56"
                                                WidthRequest="56">
                                            <Label Text="IMG"
                                                   TextColor="#9ca3af"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontSize="10" />
                                        </Border>

                                        <Border Grid.Column="1"
                                                BackgroundColor="#f3f4f6"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 22"
                                                HeightRequest="44"
                                                WidthRequest="44"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Cantidad, StringFormat='{0}x'}"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   TextColor="#374151"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Producto.Nombre}" TextColor="#111827" FontSize="16" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding PrecioUnitario, StringFormat='${0:0.00}'}" TextColor="#f26522" FontSize="16" FontAttributes="Bold" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="3"
                                               Text="{Binding Subtotal, StringFormat='${0:0.00}'}"
                                               FontSize="16"
                                               TextColor="#111827"
                                               VerticalOptions="Center" />

                                        <Label Grid.Column="4"
                                               
                                               FontSize="16"
                                               TextColor="#9ca3af"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <BoxView HeightRequest="1" Color="#eceff3" />

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Text="Subtotal" TextColor="#111827" FontSize="18" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Subtotal, StringFormat='${0:0.00}'}" TextColor="#111827" FontSize="18" />

                            <Label Grid.Row="1" Text="Impuestos (15%)" TextColor="#111827" FontSize="18" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Impuestos, StringFormat='${0:0.00}'}" TextColor="#111827" FontSize="18" />

                            <Label Grid.Row="2" Text="TOTAL" TextColor="#111827" FontSize="22" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding Total, StringFormat='${0:0.00}'}" TextColor="#f26522" FontSize="42" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#e5e7eb"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Observaciones" FontSize="34" FontAttributes="Bold" TextColor="#111827" />
                        <Label Text="{Binding Observaciones}" FontSize="17" TextColor="#374151" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="ENVIAR A COCINA"
                            FontAttributes="Bold"
                            FontSize="13"
                            HeightRequest="56"
                            CornerRadius="12"
                            BackgroundColor="#f26522"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="EN_COCINA"
                            IsVisible="{Binding PuedeEnviarCocina}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                    <Button Grid.Column="1"
                            Text="MARCAR COMO LISTO"
                            FontAttributes="Bold"
                            FontSize="13"
                            HeightRequest="56"
                            CornerRadius="12"
                            BackgroundColor="#2563eb"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="LISTO_PARA_ENTREGA"
                            IsVisible="{Binding PuedeMarcarListo}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                    <Button Grid.Column="2"
                            Text="ENTREGAR AL CLIENTE"
                            FontAttributes="Bold"
                            FontSize="13"
                            HeightRequest="56"
                            CornerRadius="12"
                            BackgroundColor="#16a34a"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="COMPLETADO"
                            IsVisible="{Binding PuedeEntregarCliente}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                </Grid>

                <Label Text="{Binding MensajeCambio}"
                       FontSize="13"
                       TextColor="#10b981"
                       HorizontalOptions="Center"
                       IsVisible="{Binding MensajeCambio, Converter={StaticResource StringToBoolConverter}}" />

                <Border BackgroundColor="White"
                        Stroke="#e5e7eb"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Historial del pedido"
                               FontSize="34"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <CollectionView ItemsSource="{Binding Historial}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:PedidoTimelineItem">
                                    <Grid ColumnDefinitions="82,22,*"
                                          Padding="0,4">
                                        <Label Grid.Column="0"
                                               Text="{Binding Hora}"
                                               FontSize="15"
                                               TextColor="#111827"
                                               VerticalOptions="Start" />

                                        <Grid Grid.Column="1" RowDefinitions="16,*">
                                            <Border Grid.Row="0"
                                                    BackgroundColor="{Binding DotColor, Converter={StaticResource HexToColorConverter}}"
                                                    Stroke="#ffffff"
                                                    StrokeThickness="2"
                                                    WidthRequest="14"
                                                    HeightRequest="14"
                                                    StrokeShape="RoundRectangle 7"
                                                    HorizontalOptions="Center" />

                                            <BoxView Grid.Row="1"
                                                     WidthRequest="2"
                                                     Color="#d1d5db"
                                                     HorizontalOptions="Center"
                                                     IsVisible="{Binding MostrarLinea}" />
                                        </Grid>

                                        <VerticalStackLayout Grid.Column="2" Spacing="0">
                                            <Label Text="{Binding Evento}"
                                                   FontSize="16"
                                                   TextColor="#111827" />
                                            <Label Text="{Binding Responsable}"
                                                   FontSize="14"
                                                   TextColor="#6b7280"
                                                   IsVisible="{Binding Responsable, Converter={StaticResource StringToBoolConverter}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#e5e7eb"
                        StrokeShape="RoundRectangle 16"
                        Padding="14"
                        Margin="0,0,0,16">
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding TituloPedido}" FontSize="16" FontAttributes="Bold" TextColor="#111827" />
                            <Label Text="{Binding FechaTexto, StringFormat='Creado: {0}'}" FontSize="14" TextColor="#6b7280" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="CANCELAR PEDIDO"
                                BackgroundColor="Transparent"
                                BorderColor="#f97316"
                                BorderWidth="1"
                                TextColor="#ef4444"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                Command="{Binding CancelarPedidoCommand}"
                                IsVisible="{Binding PuedeCancelarPedido}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                    </Grid>
                </Border>

                <Button Text="Ir a pagar"
                        Command="{Binding IrAPagarCommand}"
                        HeightRequest="52"
                        BackgroundColor="#f59e0b"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Margin="0,0,0,18"
                        IsVisible="{Binding PuedeIrAPagar}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
