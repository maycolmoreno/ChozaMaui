<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ChozaMaui.Models"
             xmlns:viewModels="clr-namespace:ChozaMaui.ViewModels"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.PedidoDetallePage"
             x:DataType="viewModels:PedidoDetalleViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Surface}">
    <Grid RowDefinitions="Auto,*">
    <controls:PosHeaderView Grid.Row="0"
                            MostrarVolver="True"
                            BackCommand="{Binding VolverCommand}"
                            InicialesUsuario="{Binding InicialesUsuario}"
                            NombreUsuario="{Binding NombreUsuarioHeader}"
                            RolUsuario="{Binding RolUsuarioHeader}"
                            Kpi1Titulo="{Binding HeaderKpi1Titulo}"
                            Kpi1Valor="{Binding HeaderKpi1Valor}"
                            Kpi2Titulo="{Binding HeaderKpi2Titulo}"
                            Kpi2Valor="{Binding HeaderKpi2Valor}"
                            Kpi3Titulo="{Binding HeaderKpi3Titulo}"
                            Kpi3Valor="{Binding HeaderKpi3Valor}"
                            TotalAlertas="{Binding TotalAlertasHeader}"
                            NotificacionesCommand="{Binding IrNotificacionesCommand}"
                            RefreshCommand="{Binding CargarCommand}" />

    <CollectionView Grid.Row="1"
                    ItemsSource="{Binding Detalles}"
                    SelectionMode="None"
                    Margin="16,14,16,0">
        <CollectionView.Header>
            <VerticalStackLayout Spacing="14">

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource Danger}"
                       FontSize="13"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Border BackgroundColor="{StaticResource PrimaryLight}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 26"
                                    WidthRequest="52"
                                    HeightRequest="52">
                                <Label Text="M"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding MesaTexto}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding MesaCapacidadTexto}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource Border}" />

                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="C"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label Text="{Binding ClienteTexto}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding ClienteTelefonoTexto}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="U"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label Text="{Binding MeseroTexto}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding MeseroHoraTexto}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,14,14,6">
                    <Label Text="Productos"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </Border>
            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:PedidoDetalleResponse">
                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="0"
                        Padding="14,7">
                    <Grid ColumnDefinitions="48,*,Auto"
                          ColumnSpacing="10">
                        <Border BackgroundColor="{StaticResource SurfaceSunken}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="48"
                                WidthRequest="48">
                            <Label Text="{Binding Cantidad, StringFormat='{0}x'}"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="{Binding Producto.Nombre}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding PrecioUnitario, StringFormat='${0:0.00}'}"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text="{Binding Subtotal, StringFormat='${0:0.00}'}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.Footer>
            <VerticalStackLayout Spacing="14" Padding="0,0,0,24">
                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                    <VerticalStackLayout Spacing="12">
                        <BoxView HeightRequest="1"
                                 Color="{StaticResource Border}" />

                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="6">
                            <Label Text="Consumo"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Subtotal, StringFormat='${0:0.00}'}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextPrimary}" />

                            <Label Grid.Row="1"
                                   Text="Total pedido"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Total, StringFormat='${0:0.00}'}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Observaciones"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding Observaciones}"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10">
                    <Button Text="ENVIAR A COCINA"
                            FontAttributes="Bold"
                            FontSize="15"
                            HeightRequest="54"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="EN_COCINA"
                            IsVisible="{Binding PuedeEnviarCocina}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                    <Button Text="INICIAR PREPARACION"
                            FontAttributes="Bold"
                            FontSize="15"
                            HeightRequest="54"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource Info}"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="EN_COCINA"
                            IsVisible="{Binding PuedeIniciarPreparacion}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                    <Button Text="MARCAR COMO LISTO"
                            FontAttributes="Bold"
                            FontSize="15"
                            HeightRequest="54"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="LISTO_PARA_ENTREGA"
                            IsVisible="{Binding PuedeMarcarListo}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                    <Button Text="ENTREGAR AL CLIENTE"
                            FontAttributes="Bold"
                            FontSize="15"
                            HeightRequest="54"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource Success}"
                            TextColor="White"
                            Command="{Binding CambiarEstadoRapidoCommand}"
                            CommandParameter="COMPLETADO"
                            IsVisible="{Binding PuedeEntregarCliente}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
                </VerticalStackLayout>

                <Label Text="{Binding MensajeCambio}"
                       FontSize="13"
                       TextColor="{StaticResource Success}"
                       HorizontalOptions="Center"
                       IsVisible="{Binding MensajeCambio, Converter={StaticResource StringToBoolConverter}}" />

                <Border BackgroundColor="White"
                        Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Historial"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Historial}"
                                             Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:PedidoTimelineItem">
                                    <Grid ColumnDefinitions="58,18,*"
                                          Padding="0,5"
                                          ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="{Binding Hora}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextSecondary}" />
                                            <Label Text="{Binding FechaTexto}"
                                                   FontSize="10"
                                                   TextColor="{StaticResource TextMuted}"
                                                   IsVisible="{Binding FechaTexto, Converter={StaticResource StringToBoolConverter}}" />
                                        </VerticalStackLayout>

                                        <Grid Grid.Column="1"
                                              RowDefinitions="14,*">
                                            <Border BackgroundColor="{Binding DotColor, Converter={StaticResource HexToColorConverter}}"
                                                    Stroke="White"
                                                    StrokeThickness="2"
                                                    WidthRequest="14"
                                                    HeightRequest="14"
                                                    StrokeShape="RoundRectangle 7"
                                                    HorizontalOptions="Center" />

                                            <BoxView Grid.Row="1"
                                                     WidthRequest="2"
                                                     Color="{StaticResource Border}"
                                                     HorizontalOptions="Center"
                                                     IsVisible="{Binding MostrarLinea}" />
                                        </Grid>

                                        <VerticalStackLayout Grid.Column="2"
                                                             Spacing="1">
                                            <Label Text="{Binding Evento}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding Responsable}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   IsVisible="{Binding Responsable, Converter={StaticResource StringToBoolConverter}}" />
                                            <Label Text="{Binding EstadoCambioTexto}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextMuted}"
                                                   IsVisible="{Binding EstadoCambioTexto, Converter={StaticResource StringToBoolConverter}}" />
                                            <Label Text="{Binding Observacion}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextMuted}"
                                                   IsVisible="{Binding Observacion, Converter={StaticResource StringToBoolConverter}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Ir a pagar"
                        Command="{Binding IrAPagarCommand}"
                        HeightRequest="54"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        IsVisible="{Binding PuedeIrAPagar}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                <Button Text="Cancelar pedido"
                        BackgroundColor="White"
                        BorderColor="{StaticResource DangerLight}"
                        BorderWidth="1"
                        TextColor="{StaticResource Danger}"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        HeightRequest="50"
                        Command="{Binding CancelarPedidoCommand}"
                        IsVisible="{Binding PuedeCancelarPedido}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
            </VerticalStackLayout>
        </CollectionView.Footer>
    </CollectionView>
    </Grid>
</ContentPage>
