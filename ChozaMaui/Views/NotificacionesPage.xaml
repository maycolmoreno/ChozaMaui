<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChozaMaui.ViewModels"
             xmlns:m="clr-namespace:ChozaMaui.Models"
             xmlns:controls="clr-namespace:ChozaMaui.Views.Controls"
             x:Class="ChozaMaui.Views.NotificacionesPage"
             x:DataType="vm:NotificacionesViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="True"
             BackgroundColor="{StaticResource Surface}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── HEADER COMPACTO ── -->
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource Primary}"
              Padding="16,44,16,14"
              ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="10">

            <Border Grid.Column="0"
                    BackgroundColor="#FB923C"
                    StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    Padding="8,6">
                <Label Text="LC" FontSize="14" FontAttributes="Bold" TextColor="White" />
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="Avisos"
                       FontSize="16" FontAttributes="Bold" TextColor="White" />
                <Label Text="Centro de notificaciones"
                       FontSize="11" TextColor="#FFEDD5" />
            </VerticalStackLayout>

            <!-- Badge no leídas -->
            <Border Grid.Column="2"
                    BackgroundColor="{StaticResource Danger}"
                    StrokeShape="RoundRectangle 14"
                    Stroke="Transparent"
                    Padding="10,5"
                    VerticalOptions="Center"
                    IsVisible="{Binding TotalNoLeidas, Converter={StaticResource IntIsNotZeroConverter}}">
                <Label Text="{Binding TotalNoLeidas}"
                       FontSize="13" FontAttributes="Bold" TextColor="White" />
            </Border>

            <controls:ConnectivityActionsView Grid.Column="3"
                                              RefreshCommand="{Binding CargarCommand}"
                                              VerticalOptions="Center" />
        </Grid>

        <!-- ── LISTA DE NOTIFICACIONES ── -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding CargarCommand}"
                     RefreshColor="{StaticResource Primary}">

            <CollectionView ItemsSource="{Binding Notificaciones}"
                            SelectionMode="None">

                <!-- Header: Marcar todas como leídas -->
                <CollectionView.Header>
                    <Grid Padding="16,14,16,4"
                          ColumnDefinitions="*,Auto"
                          IsVisible="{Binding HayNotificaciones}">
                        <Label Text="Hoy"
                               Style="{StaticResource SectionTitle}"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="Marcar todas leídas"
                                Command="{Binding MarcarTodasLeidasCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontAttributes="Bold"
                                FontSize="13"
                                Padding="4,0" />
                    </Grid>
                </CollectionView.Header>

                <!-- Estado vacío -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="12"
                                         Margin="0,80">
                        <Label Text="🔔" FontSize="56" HorizontalOptions="Center" />
                        <Label Text="Sin notificaciones"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" />
                        <Label Text="Todo está al día. ¡Buen trabajo!"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- TARJETA DE NOTIFICACIÓN -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:Notificacion">

                        <Border Margin="16,0,16,10"
                                StrokeShape="RoundRectangle 18"
                                Stroke="{StaticResource Border}"
                                Padding="14">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Leida}" Value="False">
                                    <Setter Property="BackgroundColor" Value="White" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding Leida}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirAccionCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="12">

                                <!-- Icono tipo -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        StrokeShape="RoundRectangle 14"
                                        Stroke="Transparent"
                                        HeightRequest="48" WidthRequest="48"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding IconoTipo}"
                                           FontSize="22"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Contenido -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="3"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Titulo}"
                                           FontSize="14" FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Leida}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Leida}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Label Text="{Binding Descripcion}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding TiempoTexto}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>

                                <!-- Indicador no leída -->
                                <BoxView Grid.Column="2"
                                         BackgroundColor="{StaticResource Primary}"
                                         WidthRequest="8" HeightRequest="8"
                                         CornerRadius="4"
                                         VerticalOptions="Center"
                                         IsVisible="{Binding Leida, Converter={StaticResource InvertBoolConverter}}" />

                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
